# EXTRA_LIBS: net,net_server,cipher
use Collection, Data.JSON, System.IO.Net, Web.HTTP, Web.HTTP.Server, Web.HTTP.Server.MCP;

#
# Tracks whether ListResources was called as a side-effect of
# resources/templates/list (was a bug: a stray call was present).
#
class TrackingMcpHandler from McpRequestHandler {
	@resources_side_effect : static : Bool;

	New() { Parent(); }

	method : ListResources() ~ Vector<ResourceItem> {
		@resources_side_effect := true;
		return Vector->New()<ResourceItem>;
	}

	method : ListTemplates() ~ Vector<ResourceTemplate> {
		return Vector->New()<ResourceTemplate>;
	}

	method : GetResource(uri : Url) ~ Vector<ResourceContent> {
		return Vector->New()<ResourceContent>;
	}

	method : ListTools() ~ Vector<ToolItem> {
		return Vector->New()<ToolItem>;
	}

	method : CallTool(name : String, arguments : JsonElement) ~ Vector<ToolContent> {
		return Vector->New()<ToolContent>;
	}

	method : ListPrompts() ~ Vector<PromptItem> {
		return Vector->New()<PromptItem>;
	}

	method : CallPrompt(name : String, arguments : JsonElement) ~ Vector<PromptMessage> {
		return Vector->New()<PromptMessage>;
	}

	function : WasResourcesSideEffect() ~ Bool {
		return @resources_side_effect;
	}

	function : ResetResourcesSideEffect() ~ Nil {
		@resources_side_effect := false;
	}
}

class McpServerTest {
	@port : static : Int;

	function : Port() ~ Int {
		return @port;
	}

	function : Post(url : String, payload : String) ~ Web.HTTP.Response {
		client := HttpClient->New();
		client->AddHeader("Content-Type", "application/json");
		return client->Post(Url->New(url), payload->ToByteArray(), "application/json");
	}

	function : PostWithSession(url : String, payload : String, session_id : String) ~ Web.HTTP.Response {
		client := HttpClient->New();
		client->AddHeader("Content-Type", "application/json");
		client->AddHeader("mcp-session-id", session_id);
		return client->Post(Url->New(url), payload->ToByteArray(), "application/json");
	}

	#
	# Sends a POST, retrying a few times when the server gives a transient
	# failure under CI load: no response, the wrong status code, or an empty
	# or TRUNCATED body for a 200. Every 200 response in this test is a
	# JSON-RPC reply carrying a "result" member, so a 200 is only accepted
	# once its body parses as JSON with "result" — a partial read that
	# produced a non-empty but cut-off body retries instead of failing the
	# per-test assertions (seen as "missing result.tools" on arm64 CI).
	# The per-test assertions below still strictly validate the final response.
	#
	function : Request(url : String, payload : String, session : String, expect : Int, retries : Int) ~ Web.HTTP.Response {
		resp : Web.HTTP.Response;
		for(i := 0; i < retries; i += 1;) {
			if(session = Nil) {
				resp := Post(url, payload);
			}
			else {
				resp := PostWithSession(url, payload, session);
			};
			if(resp <> Nil & resp->GetCode() = expect) {
				if(expect <> 200) {
					return resp;
				};
				content := resp->GetContent();
				if(content <> Nil & content->Size() > 0) {
					root := JsonParser->TextToElement(content->ToString());
					if(root <> Nil & root->Get("result") <> Nil) {
						return resp;
					};
				};
			};
			System.Concurrency.Thread->Sleep(200);
		};
		return resp;
	}

	function : Main(args : String[]) ~ Nil {
		pass := true;
		@port := 18799;
		base_url := "http://localhost:{$@port}/";

		# Start MCP server in a background thread
		server_thread := System.Concurrency.Thread->New() {
			New() { Parent() }
			method : public : Run(arg : System.Base) ~ Nil {
				config_builder := JsonBuilder->New();
				elem_json := config_builder->PushObject();
				elem_json->Insert("name", "Test MCP Server");
				elem_json->Insert("instructions", "Regression test server");
				elem_json->Insert("version", "0.0.1");
				elem_json->Insert("http_port", McpServerTest->Port());
				elem_json->Insert("http_session_timeout", 30);
				elem_json->Insert("debug", false);
				config_json := config_builder->Pop();
				McpServer->Serve(config_json, TrackingMcpHandler->New());
			}
		};
		server_thread->Execute(Nil);
		System.Concurrency.Thread->Sleep(500);

		# ------------------------------------------------------------------
		# Test 1: initialize — capabilities must have "prompts", "resources",
		# and "tools" as distinct keys.  Old bug: "resources" was inserted
		# twice, silently overwriting the "prompts" capability.
		# ------------------------------------------------------------------
		init_payload := "{\"jsonrpc\":\"2.0\",\"method\":\"initialize\",\"params\":{\"protocolVersion\":\"2025-06-18\",\"capabilities\":{}},\"id\":1}";
		r1 := McpServerTest->Request(base_url, init_payload, Nil, 200, 5);

		if(r1 = Nil | r1->GetCode() <> 200) {
			code := -1; if(r1 <> Nil) { code := r1->GetCode(); };
			"  FAIL: initialize - unexpected response code {$code}"->PrintLine();
			pass := false;
		}
		else {
			root := JsonParser->TextToElement(r1->GetContent()->ToString());
			if(root = Nil | root->Get("result") = Nil) {
				"  FAIL: initialize - response is not valid JSON-RPC"->PrintLine();
				pass := false;
			}
			else {
				caps := root->Get("result")->Get("capabilities");
				if(caps = Nil) {
					"  FAIL: initialize - no capabilities object"->PrintLine();
					pass := false;
				}
				else {
					if(<>caps->Has("prompts")) {
						"  FAIL: initialize - 'prompts' capability missing"->PrintLine();
						pass := false;
					};
					if(<>caps->Has("resources")) {
						"  FAIL: initialize - 'resources' capability missing"->PrintLine();
						pass := false;
					};
					if(<>caps->Has("tools")) {
						"  FAIL: initialize - 'tools' capability missing"->PrintLine();
						pass := false;
					};
				};
			};
		};

		# ------------------------------------------------------------------
		# Test 2: ping — basic routing sanity check
		# ------------------------------------------------------------------
		ping_payload := "{\"jsonrpc\":\"2.0\",\"method\":\"ping\",\"id\":2}";
		r2 := McpServerTest->Request(base_url, ping_payload, Nil, 200, 5);

		if(r2 = Nil | r2->GetCode() <> 200) {
			code := -1; if(r2 <> Nil) { code := r2->GetCode(); };
			"  FAIL: ping - unexpected response code {$code}"->PrintLine();
			pass := false;
		};

		# ------------------------------------------------------------------
		# Test 3: resources/templates/list must NOT call ListResources() as a
		# side effect.  Old bug: a stray ListResources() call was present whose
		# result was discarded.
		# ------------------------------------------------------------------
		TrackingMcpHandler->ResetResourcesSideEffect();
		templates_payload := "{\"jsonrpc\":\"2.0\",\"method\":\"resources/templates/list\",\"id\":3}";
		r3 := McpServerTest->Request(base_url, templates_payload, Nil, 200, 5);

		if(r3 = Nil | r3->GetCode() <> 200) {
			code := -1; if(r3 <> Nil) { code := r3->GetCode(); };
			"  FAIL: resources/templates/list - unexpected response code {$code}"->PrintLine();
			pass := false;
		};
		System.Concurrency.Thread->Sleep(100);
		if(TrackingMcpHandler->WasResourcesSideEffect()) {
			"  FAIL: resources/templates/list - spuriously called ListResources()"->PrintLine();
			pass := false;
		};

		# ------------------------------------------------------------------
		# Test 4: unknown session ID must return 404.  The server checks
		# session_id header and returns 404 when the session is not found.
		# ------------------------------------------------------------------
		tools_payload := "{\"jsonrpc\":\"2.0\",\"method\":\"tools/list\",\"id\":4}";
		r4 := McpServerTest->Request(base_url, tools_payload, "invalid-session-does-not-exist", 404, 5);

		if(r4 = Nil | r4->GetCode() <> 404) {
			code := -1; if(r4 <> Nil) { code := r4->GetCode(); };
			"  FAIL: invalid session - expected 404, got {$code}"->PrintLine();
			pass := false;
		};

		# ------------------------------------------------------------------
		# Test 5: tools/list without a session returns 200 and a tools array
		# ------------------------------------------------------------------
		r5 := McpServerTest->Request(base_url, tools_payload, Nil, 200, 5);

		if(r5 = Nil | r5->GetCode() <> 200) {
			code := -1; if(r5 <> Nil) { code := r5->GetCode(); };
			"  FAIL: tools/list - unexpected response code {$code}"->PrintLine();
			pass := false;
		}
		else {
			root5 := JsonParser->TextToElement(r5->GetContent()->ToString());
			if(root5 = Nil | root5->Get("result") = Nil | root5->Get("result")->Get("tools") = Nil) {
				"  FAIL: tools/list - response missing result.tools"->PrintLine();
				pass := false;
			};
		};

		WebServer->Stop();

		if(pass) {
			"PASS: MCP server tests"->PrintLine();
		}
		else {
			"FAIL: MCP server tests"->PrintLine();
			Runtime->Exit(1);
		};
	}
}
