class Counter {
  @count : Int;
  @total_created : static : Int;

  New() {
    @count := 0;
    @total_created += 1;
  }

  method : public : Increment() ~ Nil {
    @count += 1;
  }

  method : public : GetCount() ~ Int {
    return @count;
  }

  method : public : ToString() ~ String {
    return "Counter={$@count}";
  }

  function : GetTotalCreated() ~ Int {
    return @total_created;
  }
}

class Main {
  function : Main(args : String[]) ~ Nil {
    values := Int->New[5];
    each(i : values) {
      values[i] := i * 10;
    };

    sum := 0;
    each(i : values) {
      sum += values[i];
    };

    foo := Counter->New();
    foo->Increment();
    foo->Increment();
    foo->Increment();

    foo := Counter->New();

    msg := foo->ToString();
    count := foo->GetCount();
    total := Counter->GetTotalCreated();
    "Sum={$sum}, {$msg}, total_created={$total}"->PrintLine();

    if(count > 2) {
      "Count is greater than 2"->PrintLine();
    };

    result := Factorial(5);
    "Factorial(5)={$result}"->PrintLine();
  }

  function : Factorial(n : Int) ~ Int {
    if(n <= 1) {
      return 1;
    };
    return n * Factorial(n - 1);
  }
}
