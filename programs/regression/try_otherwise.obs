#~
# Try/Otherwise Error Handling Test
# Tests the 'try' expression and 'otherwise' keyword for error handling
~#

class TryOtherwiseTest {
  function : Main(args : String[]) ~ Nil {
    "Testing try/otherwise error handling..."->PrintLine();

    pass := true;

    # Test 1: otherwise with Nil value
    val : String;
    result := val otherwise "default";
    if(result <> "default") {
      pass := false;
      "  FAIL: Nil otherwise 'default' = {$result}"->PrintLine();
    };

    # Test 2: otherwise with non-Nil value
    val2 := "hello";
    result2 := val2 otherwise "world";
    if(result2 <> "hello") {
      pass := false;
      "  FAIL: 'hello' otherwise 'world' = {$result2}"->PrintLine();
    };

    # Test 3: try with Nil dereference
    obj : String;
    val3 := try obj->Size();
    if(val3 <> 0) {
      pass := false;
      "  FAIL: try nil->Size() should be 0 (Nil)"->PrintLine();
    };

    # Test 4: try + otherwise composition
    obj2 : String;
    val4 := try obj2->Size() otherwise -1;
    if(val4 <> -1) {
      pass := false;
      "  FAIL: try nil->Size() otherwise -1 = {$val4}"->PrintLine();
    };

    # Test 5: try with successful expression
    obj3 := "hello";
    val5 := try obj3->Size();
    if(val5 <> 5) {
      pass := false;
      "  FAIL: try 'hello'->Size() = {$val5}"->PrintLine();
    };

    # Test 6: try + otherwise with successful expression
    obj4 := "world";
    val6 := try obj4->Size() otherwise -1;
    if(val6 <> 5) {
      pass := false;
      "  FAIL: try 'world'->Size() otherwise -1 = {$val6}"->PrintLine();
    };

    if(pass) {
      "PASS: Try/otherwise error handling"->PrintLine();
    } else {
      "FAIL: Try/otherwise error handling"->PrintLine();
    };
  }
}
