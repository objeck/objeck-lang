{
    "adapters": {
        "objeck": {
            "name": "objeck",
            "command": [
                "C:\\Users\\objec\\.objeck-lsp\\bin\\obd.exe",
                "--dap"
            ],
            "env": {
                "OBJECK_LIB_PATH": "C:\\Users\\objec\\.objeck-lsp\\lib"
            }
        }
    },
    "configurations": {
        "Debug current Objeck file": {
            "adapter": "objeck",
            "configuration": {
                "request": "launch",
                "type": "objeck",
                "program": "${workspaceRoot}/${fileBasenameNoExtension}.obe",
                "sourceDir": "${workspaceRoot}"
            }
        },
        "Debug debugger_test.obe": {
            "adapter": "objeck",
            "configuration": {
                "request": "launch",
                "type": "objeck",
                "program": "${workspaceRoot}/debugger_test.obe",
                "sourceDir": "${workspaceRoot}"
            }
        }
    }
}
