# EXTRA_LIBS: ai,gen_collect
# JIT_DISABLE
#~
Regression tests for System.AI reinforcement learning using a 6-state chain
world (move right to reach the goal at state 5, +10 at the goal, -1 per
step): QLearning and Sarsa both learn the always-right policy, and value
iteration on the explicit MDP produces the same policy with the expected
discounted values.
~#
use System.AI;

#~
Chain world: states 0..5, goal at 5. Action 0 = left, 1 = right.
Reward: +10.0 entering the goal, -1.0 otherwise.
~#
class ChainWorld implements Environment {
	New() {}

	method : public : GetNumStates() ~ Int {
		return 6;
	}

	method : public : GetNumActions() ~ Int {
		return 2;
	}

	method : public : Reset() ~ Int {
		return 0;
	}

	method : public : Step(state : Int, action : Int) ~ System.AI.StepResult {
		next := state;
		if(action = 1) {
			next := state + 1;
		}
		else if(state > 0) {
			next := state - 1;
		};

		if(next = 5) {
			return StepResult->New(5, 10.0, true);
		};

		return StepResult->New(next, -1.0, false);
	}
}

class AiRlTest {
	function : Main(args : String[]) ~ Nil {
		pass := true;

		env := ChainWorld->New();

		# --- Q-learning: always-right policy from every non-goal state ---
		q_agent := QLearning->New(0.2, 0.95, 0.2, 7);
		if(q_agent->BestAction(0) <> -1) {
			pass := false;
			"  FAIL: untrained q best-action"->PrintLine();
		};

		if(<>q_agent->Train(env, 400, 60)) {
			pass := false;
			"  FAIL: q-learning train"->PrintLine();
		}
		else {
			each(s : 5) {
				if(q_agent->BestAction(s) <> 1) {
					a := q_agent->BestAction(s);
					pass := false;
					"  FAIL: q-learning policy state {$s} action {$a}"->PrintLine();
				};
			};

			# right beats left in the Q values themselves
			q := q_agent->GetQ();
			if(q[0,1] <= q[0,0]) {
				pass := false;
				"  FAIL: q-learning value ordering"->PrintLine();
			};
		};

		# --- SARSA: same policy on this deterministic chain ---
		s_agent := Sarsa->New(0.2, 0.95, 0.2, 7);
		if(<>s_agent->Train(env, 400, 60)) {
			pass := false;
			"  FAIL: sarsa train"->PrintLine();
		}
		else {
			each(s : 5) {
				if(s_agent->BestAction(s) <> 1) {
					pass := false;
					"  FAIL: sarsa policy state {$s}"->PrintLine();
				};
			};
		};

		# --- explicit MDP + value iteration: same chain, known values ---
		mdp := MarkovDecisionProcess->New(6, 2);
		each(s : 5) {
			# right
			if(s = 4) {
				mdp->AddTransition(4, 1, 5, 1.0, 10.0);
			}
			else {
				mdp->AddTransition(s, 1, s + 1, 1.0, -1.0);
			};
			# left
			if(s = 0) {
				mdp->AddTransition(0, 0, 0, 1.0, -1.0);
			}
			else {
				mdp->AddTransition(s, 0, s - 1, 1.0, -1.0);
			};
		};

		if(mdp->AddTransition(9, 0, 0, 1.0, 0.0)) {
			pass := false;
			"  FAIL: invalid transition accepted"->PrintLine();
		};

		if(<>mdp->Solve(0.95, 0.000001, 1000)) {
			pass := false;
			"  FAIL: mdp solve"->PrintLine();
		}
		else {
			policy := mdp->GetPolicy();
			each(s : 5) {
				if(policy[s] <> 1) {
					pass := false;
					"  FAIL: mdp policy state {$s}"->PrintLine();
				};
			};

			# V(4) = 10; V(3) = -1 + 0.95*10 = 8.5
			values := mdp->GetValues();
			if(Float->Abs(values[4] - 10.0) > 0.001 | Float->Abs(values[3] - 8.5) > 0.001) {
				v4 := values[4]; v3 := values[3];
				pass := false;
				"  FAIL: mdp values v4={$v4} v3={$v3}"->PrintLine();
			};

			# values increase toward the goal
			each(s : 4) {
				if(values[s] >= values[s + 1]) {
					pass := false;
					"  FAIL: mdp value ordering state {$s}"->PrintLine();
				};
			};
		};

		if(pass) {
			"PASS: AI reinforcement learning tests"->PrintLine();
		}
		else {
			"FAIL: AI reinforcement learning tests"->PrintLine();
		};
	}
}
