use Database.ODBC;

bundle Default {
	class SqlTest {
		function : Main(args : String[]) ~ Nil {
			Run();
		}

		function : native : Run() ~ Nil {
			conn := Connection->New("udc", "", "");
			if(conn->IsOpen()) {
				ps := conn->CreateParameterStatement("INSERT INTO Foo(Bar) VALUES(?)");
				ps->SetInt(1);
				ps->Update()->PrintLine();
				ps->Close();
				conn->Close();
			};
		}
	}
}
