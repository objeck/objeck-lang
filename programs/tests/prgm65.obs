use Collection;

class Test {
	function : Main(args : String[]) ~ Nil {
		# Test Vector with Swap
		v := Vector->New()<IntRef>;
		v->AddBack(23);
		v->AddBack(145);
		v->AddBack(17);
		v->AddBack(8);

		each(i : v) {
			v->Get(i)->PrintLine();
		};

		# Test Swap
		v->Swap(0, 3);
		v->Get(0)->PrintLine();
		v->Get(3)->PrintLine();

		"----------------"->PrintLine();

		# Test CompareVector with Sort and First
		ints := CompareVector->New()<IntRef>;
		ints->AddBack(23);
		ints->AddBack(145);
		ints->AddBack(17);
		ints->AddBack(8);

		# Test First
		ints->First()->PrintLine();

		# Test Sort
		ints->Sort();

		each(i : ints) {
			ints->Get(i)->PrintLine();
		};

		"----------------"->PrintLine();

		# Test CompareVector with FloatRef
		floats := CompareVector->New()<FloatRef>;
		floats->AddBack(3.5);
		floats->AddBack(13.45);
		floats->AddBack(6.2);
		floats->AddBack(46.12);

		# Test First
		floats->First()->PrintLine();

		# Test Sort
		floats->Sort();

		each(i : floats) {
			floats->Get(i)->PrintLine();
		};

		"----------------"->PrintLine();

		# Test Limit
		limited := ints->Limit(2);
		limited->Size()->PrintLine();
		each(i : limited) {
			limited->Get(i)->PrintLine();
		};
	}
}
