use Collection;

class Test {
	function : Main(args : String[]) ~ Nil {
		hash := Hash->New()<String, String>;
		hash->Insert("pug", "aa");
		hash->Insert("terrier", "ca");
		hash->Insert("bangel", "ab");

		# Test Remove
		hash->Remove("pug");

		value := hash->Find("pug");
		if(value <> Nil) {
			value->PrintLine();
		};

		value := hash->Find("bangel");
		if(value <> Nil) {
			value->PrintLine();
		};

		# Test Has
		hash->Has("terrier")->PrintLine();
		hash->Has("randy")->PrintLine();

		value := hash->Find("terrier");
		if(value <> Nil) {
			value->PrintLine();
		};

		hash->Size()->PrintLine();

		"----------------"->PrintLine();

		# Test Insert duplicate key (should update value)
		hash2 := Hash->New()<String, String>;
		hash2->Insert("key1", "original");
		hash2->Find("key1")->PrintLine();

		hash2->Insert("key1", "updated");
		hash2->Find("key1")->PrintLine();

		hash2->Size()->PrintLine();
	}
}
