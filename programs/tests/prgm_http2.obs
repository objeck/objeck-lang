use Web.HTTP, Collection;

class Http2Test {
	function : Main(args : String[]) ~ Nil {
		"--- HTTP/2 Client Tests ---"->PrintLine();

		TestGet();
		TestPost();
		TestHeaders();
		TestConnectionReuse();
		TestQuickGet();
		TestQuickPost();

		"--- Done ---"->PrintLine();
	}

	function : TestGet() ~ Nil {
		"Test 1: HTTP/2 GET /get... "->Print();
		client := Http2Client->New("httpbin.org");
		if(<>client->IsConnected()) {
			"SKIP (no network or nghttp2 not built)"->PrintLine();
			return;
		};

		resp := client->Get("/get");
		client->Close();

		if(resp <> Nil & resp->GetCode() = 200) {
			"PASS (status={$resp->GetCode()})"->PrintLine();
		}
		else {
			code := -1;
			if(resp <> Nil) {
				code := resp->GetCode();
			};
			if(IsTransient(code)) {
				"SKIP (upstream status={$code})"->PrintLine();
			}
			else {
				"FAIL (status={$code})"->PrintLine();
			};
		};
	}

	function : TestPost() ~ Nil {
		"Test 2: HTTP/2 POST /post with JSON body... "->Print();
		client := Http2Client->New("httpbin.org");
		if(<>client->IsConnected()) {
			"SKIP (no network or nghttp2 not built)"->PrintLine();
			return;
		};

		body := "{\"key\":\"value\"}"->ToByteArray();
		resp := client->Post("/post", body, "application/json");
		client->Close();

		if(resp <> Nil & resp->GetCode() = 200) {
			content := resp->GetContent();
			content_str := "";
			if(content <> Nil) {
				content_str := String->New(content);
			};
			if(content_str->Has("value")) {
				"PASS (body echoed back)"->PrintLine();
			}
			else {
				"PASS (status=200, body not verified)"->PrintLine();
			};
		}
		else {
			code := -1;
			if(resp <> Nil) {
				code := resp->GetCode();
			};
			if(IsTransient(code)) {
				"SKIP (upstream status={$code})"->PrintLine();
			}
			else {
				"FAIL (status={$code})"->PrintLine();
			};
		};
	}

	function : TestHeaders() ~ Nil {
		"Test 3: HTTP/2 custom request header... "->Print();
		client := Http2Client->New("httpbin.org");
		if(<>client->IsConnected()) {
			"SKIP (no network or nghttp2 not built)"->PrintLine();
			return;
		};

		client->AddHeader("x-test-header", "objeck-h2");
		resp := client->Get("/headers");
		client->Close();

		if(resp <> Nil & resp->GetCode() = 200) {
			content := resp->GetContent();
			content_str := "";
			if(content <> Nil) {
				content_str := String->New(content);
			};
			if(content_str->Has("objeck-h2")) {
				"PASS (custom header echoed)"->PrintLine();
			}
			else {
				"PASS (status=200)"->PrintLine();
			};
		}
		else {
			code := -1;
			if(resp <> Nil) {
				code := resp->GetCode();
			};
			if(IsTransient(code)) {
				"SKIP (upstream status={$code})"->PrintLine();
			}
			else {
				"FAIL (status={$code})"->PrintLine();
			};
		};
	}

	function : TestConnectionReuse() ~ Nil {
		"Test 4: HTTP/2 connection reuse (3 sequential requests)... "->Print();
		client := Http2Client->New("httpbin.org");
		if(<>client->IsConnected()) {
			"SKIP (no network or nghttp2 not built)"->PrintLine();
			return;
		};

		ok := true;
		transient := false;

		resp1 := client->Get("/get");
		if(resp1 = Nil | resp1->GetCode() <> 200) {
			ok := false;
			c1 := -1;
			if(resp1 <> Nil) { c1 := resp1->GetCode(); };
			if(IsTransient(c1)) { transient := true; };
		};

		resp2 := client->Get("/ip");
		if(resp2 = Nil | resp2->GetCode() <> 200) {
			ok := false;
			c2 := -1;
			if(resp2 <> Nil) { c2 := resp2->GetCode(); };
			if(IsTransient(c2)) { transient := true; };
		};

		resp3 := client->Get("/user-agent");
		if(resp3 = Nil | resp3->GetCode() <> 200) {
			ok := false;
			c3 := -1;
			if(resp3 <> Nil) { c3 := resp3->GetCode(); };
			if(IsTransient(c3)) { transient := true; };
		};

		client->Close();

		if(ok) {
			"PASS (all 3 requests succeeded)"->PrintLine();
		}
		else if(transient) {
			"SKIP (upstream unavailable)"->PrintLine();
		}
		else {
			"FAIL (one or more requests failed)"->PrintLine();
		};
	}

	# A response is "transient" when the client completed the HTTP exchange but the
	# upstream service was unavailable (5xx) or rate-limited (429), or the request
	# could not be completed at all (code < 0 / Nil response). These reflect the
	# external service / network, not the Objeck HTTP client, so they SKIP not FAIL.
	function : IsTransient(code : Int) ~ Bool {
		return code < 0 | code = 429 | code >= 500;
	}

	function : TestQuickGet() ~ Nil {
		"Test 5: HTTP/2 QuickGet httpbin.org/get... "->Print();
		url := Url->New("https://httpbin.org/get");
		resp := Http2Client->QuickGet(url);
		if(resp <> Nil & resp->GetCode() = 200) {
			"PASS (status=200)"->PrintLine();
		}
		else {
			code := -1;
			if(resp <> Nil) {
				code := resp->GetCode();
			};
			if(IsTransient(code)) {
				"SKIP (upstream status={$code})"->PrintLine();
			}
			else {
				"FAIL (status={$code})"->PrintLine();
			};
		};
	}

	function : TestQuickPost() ~ Nil {
		"Test 6: HTTP/2 QuickPost httpbin.org/post... "->Print();
		url := Url->New("https://httpbin.org/post");
		body := "{\"quick\":\"post\"}"->ToByteArray();
		resp := Http2Client->QuickPost(url, body, "application/json");
		if(resp <> Nil & resp->GetCode() = 200) {
			"PASS (status=200)"->PrintLine();
		}
		else {
			code := -1;
			if(resp <> Nil) {
				code := resp->GetCode();
			};
			if(IsTransient(code)) {
				"SKIP (upstream status={$code})"->PrintLine();
			}
			else {
				"FAIL (status={$code})"->PrintLine();
			};
		};
	}
}
