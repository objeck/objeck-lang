bundle Default {
	class SpectralNormNative {
		function : Main(args : String[]) ~ Nil {
			n := 2000;
			if (args->Size() > 0) {
				n := args[0]->ToInt();
			};
			Approximate(n)->PrintLine();
		}

		# not native: allocates arrays; hot compute delegated to native inner functions
		function : Approximate(n : Int) ~ Float {
			u := Float->New[n];
			for(i:=0; i<n; i+=1;) { u[i] := 1.0; };

			v := Float->New[n];
			w := Float->New[n];

			for(i:=0; i<10; i+=1;) {
				MultiplyAtAv(n,u,v,w);
				MultiplyAtAv(n,v,u,w);
			};

			vBv := 0.0; vv := 0.0;
			for(i:=0; i<n; i+=1;) {
				vBv += u[i]*v[i];
				vv  += v[i]*v[i];
			};

			return (vBv/vv)->Sqrt();
		}

		# Incremental denominator: d(i,j) = (i+j)*(i+j+1)/2 + i+1.
		# d(i,0) = i*(i+1)/2 + i+1; d(i,j+1) = d(i,j) + (i+j+1).
		# Step starts at i+1 and increases by 1 each iteration.
		# Eliminates I2F and integer multiply from the inner loop.
		function : native : MultiplyAv(n : Int, v : Float[], Av : Float[]) ~ Nil {
			for(i:=0; i<n; i+=1;){
				sum := 0.0;
				d := (i*(i+1)/2 + i + 1)->As(Float);
				step := (i + 1)->As(Float);
				for(j:=0; j<n; j+=1;) {
					sum += v[j] / d;
					d += step;
					step += 1.0;
				};
				Av[i] := sum;
			};
		}

		# Incremental denominator for transpose: e(i,j) = (i+j)*(i+j+1)/2 + j+1.
		# e(i,0) = i*(i+1)/2 + 1; e(i,j+1) = e(i,j) + (i+j+2).
		# Step starts at i+2 and increases by 1 each iteration.
		function : native : MultiplyAtv(n : Int, v : Float[], Atv : Float[]) ~ Nil {
			for(i:=0;i<n;i+=1;){
				sum := 0.0;
				d := (i*(i+1)/2 + 1)->As(Float);
				step := (i + 2)->As(Float);
				for(j:=0; j<n; j+=1;) {
					sum += v[j] / d;
					d += step;
					step += 1.0;
				};
				Atv[i] := sum;
			};
		}

		# not native: delegates to native MultiplyAv/MultiplyAtv using caller-supplied work buffer
		function : MultiplyAtAv(n : Int, v : Float[], AtAv : Float[], work : Float[]) ~ Nil {
			MultiplyAv(n,v,work);
			MultiplyAtv(n,work,AtAv);
		}
	}
}
