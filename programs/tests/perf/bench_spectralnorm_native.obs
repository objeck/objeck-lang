bundle Default {
	class SpectralNormNative {
		function : Main(args : String[]) ~ Nil {
			n := 2000;
			if (args->Size() > 0) {
				n := args[0]->ToInt();
			};
			Approximate(n)->PrintLine();
		}

		# not native: allocates arrays; compute is delegated to native inner functions
		function : Approximate(n : Int) ~ Float {
			u := Float->New[n];
			for(i:=0; i<n; i+=1;) { u[i] := 1.0; };

			v := Float->New[n];
			w := Float->New[n];

			for(i:=0; i<10; i+=1;) {
				MultiplyAtAv(n,u,v,w);
				MultiplyAtAv(n,v,u,w);
			};

			vBv := 0.0; vv := 0.0;
			for(i:=0; i<n; i+=1;) {
				vBv += u[i]*v[i];
				vv  += v[i]*v[i];
			};

			return (vBv/vv)->Sqrt();
		}

		function : native : A(i : Int, j : Int) ~ Float {
			return 1.0/((i+j)*(i+j+1)/2 +i+1);
		}

		function : native : MultiplyAv(n : Int, v : Float[], Av : Float[]) ~ Nil {
			for(i:=0; i<n; i+=1;){
				Av[i] := 0;
				for (j:=0; j<n; j+=1;) { Av[i] += A(i,j)*v[j]; };
			};
		}

		function : native : MultiplyAtv(n : Int, v : Float[], Atv : Float[]) ~ Nil {
			for(i:=0;i<n;i+=1;){
				Atv[i] := 0;
				for(j:=0; j<n; j+=1;) { Atv[i] += A(j,i)*v[j]; };
			};
		}

		# not native: delegates to native MultiplyAv/MultiplyAtv using caller-supplied work buffer
		function : MultiplyAtAv(n : Int, v : Float[], AtAv : Float[], work : Float[]) ~ Nil {
			MultiplyAv(n,v,work);
			MultiplyAtv(n,work,AtAv);
		}
	}
}
