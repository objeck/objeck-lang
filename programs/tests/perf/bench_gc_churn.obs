class TempNode {
	@value : Int;
	@next : TempNode;

	New(v : Int) {
		@value := v;
	}

	method : public : SetNext(n : TempNode) ~ Nil {
		@next := n;
	}

	method : public : GetValue() ~ Int {
		return @value;
	}
}

class BenchGCChurn {
	function : Main(args : String[]) ~ Nil {
		n := 5000000;
		if(args->Size() > 0) {
			n := args[0]->ToInt();
		};

		sum := 0;

		# rapid short-lived allocations to stress GC
		for(i := 0; i < n; i += 1;) {
			node := TempNode->New(i);
			node2 := TempNode->New(i + 1);
			node->SetNext(node2);
			sum += node->GetValue();
		};

		sum->PrintLine();
	}
}
