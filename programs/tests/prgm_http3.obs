use Web.HTTP;

class Http3Test {
	function : Main(args : String[]) ~ Nil {
		"--- HTTP/3 Client Tests ---"->PrintLine();

		TestGet();
		TestPost();
		TestConnectionReuse();
		TestQuickGet();
		TestQuickPost();

		"--- Done ---"->PrintLine();
	}

	function : TestGet() ~ Nil {
		"Test 1: HTTP/3 GET quic.nginx.org/... "->Print();
		client := Http3Client->New("quic.nginx.org");
		if(<>client->IsConnected()) {
			"SKIP (no network or ngtcp2 not built)"->PrintLine();
			return;
		};

		resp := client->Get("/");
		client->Close();

		if(resp <> Nil & resp->GetCode() = 200) {
			"PASS (status=200)"->PrintLine();
		}
		else {
			code := -1;
			if(resp <> Nil) {
				code := resp->GetCode();
			};
			if(IsTransient(code)) {
				"SKIP (upstream status={$code})"->PrintLine();
			}
			else {
				"FAIL (status={$code})"->PrintLine();
			};
		};
	}

	function : TestPost() ~ Nil {
		"Test 2: HTTP/3 POST quic.nginx.org/... "->Print();
		client := Http3Client->New("quic.nginx.org");
		if(<>client->IsConnected()) {
			"SKIP (no network or ngtcp2 not built)"->PrintLine();
			return;
		};

		body := "hello=world"->ToByteArray();
		resp := client->Post("/", body, "application/x-www-form-urlencoded");
		client->Close();

		if(resp <> Nil & (resp->GetCode() = 200 | resp->GetCode() = 405 | resp->GetCode() = 404)) {
			"PASS (status={$resp->GetCode()})"->PrintLine();
		}
		else {
			code := -1;
			if(resp <> Nil) {
				code := resp->GetCode();
			};
			if(IsTransient(code)) {
				"SKIP (upstream status={$code})"->PrintLine();
			}
			else {
				"FAIL (status={$code})"->PrintLine();
			};
		};
	}

	function : TestConnectionReuse() ~ Nil {
		"Test 3: HTTP/3 sequential requests on same connection... "->Print();
		client := Http3Client->New("quic.nginx.org");
		if(<>client->IsConnected()) {
			"SKIP (no network or ngtcp2 not built)"->PrintLine();
			return;
		};

		ok := true;
		transient := false;

		resp1 := client->Get("/");
		if(resp1 = Nil | resp1->GetCode() <> 200) {
			ok := false;
			c1 := -1;
			if(resp1 <> Nil) { c1 := resp1->GetCode(); };
			if(IsTransient(c1)) { transient := true; };
		};

		resp2 := client->Get("/");
		if(resp2 = Nil | resp2->GetCode() <> 200) {
			ok := false;
			c2 := -1;
			if(resp2 <> Nil) { c2 := resp2->GetCode(); };
			if(IsTransient(c2)) { transient := true; };
		};

		client->Close();

		if(ok) {
			"PASS"->PrintLine();
		}
		else if(transient) {
			"SKIP (upstream unavailable)"->PrintLine();
		}
		else {
			"FAIL (one or more requests failed)"->PrintLine();
		};
	}

	# A response is "transient" when the client completed the HTTP exchange but the
	# upstream service was unavailable (5xx) or rate-limited (429), or the request
	# could not be completed at all (code < 0 / Nil response). These reflect the
	# external service / network, not the Objeck HTTP client, so they SKIP not FAIL.
	function : IsTransient(code : Int) ~ Bool {
		return code < 0 | code = 429 | code >= 500;
	}

	function : TestQuickGet() ~ Nil {
		"Test 4: HTTP/3 QuickGet quic.nginx.org/... "->Print();
		url := Url->New("https://quic.nginx.org/");
		resp := Http3Client->QuickGet(url);
		if(resp <> Nil & resp->GetCode() = 200) {
			"PASS (status=200)"->PrintLine();
		}
		else {
			code := -1;
			if(resp <> Nil) {
				code := resp->GetCode();
			};
			if(IsTransient(code)) {
				"SKIP (upstream status={$code})"->PrintLine();
			}
			else {
				"FAIL (status={$code})"->PrintLine();
			};
		};
	}

	function : TestQuickPost() ~ Nil {
		"Test 5: HTTP/3 QuickPost quic.nginx.org/... "->Print();
		url := Url->New("https://quic.nginx.org/");
		body := "test=data"->ToByteArray();
		resp := Http3Client->QuickPost(url, body, "application/x-www-form-urlencoded");
		if(resp <> Nil & (resp->GetCode() = 200 | resp->GetCode() = 405 | resp->GetCode() = 404)) {
			"PASS (status={$resp->GetCode()})"->PrintLine();
		}
		else {
			code := -1;
			if(resp <> Nil) {
				code := resp->GetCode();
			};
			if(IsTransient(code)) {
				"SKIP (upstream status={$code})"->PrintLine();
			}
			else {
				"FAIL (status={$code})"->PrintLine();
			};
		};
	}
}
