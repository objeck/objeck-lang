FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    build-essential \
    libssl-dev \
    libmbedtls-dev \
    libnghttp2-dev \
    libngtcp2-dev \
    libngtcp2-crypto-gnutls-dev \
    libnghttp3-dev \
    libgnutls28-dev \
    unixodbc-dev \
    libsdl2-dev \
    libsdl2-image-dev \
    libsdl2-ttf-dev \
    libsdl2-mixer-dev \
    libreadline-dev \
    libeigen3-dev \
    libmp3lame-dev \
    zlib1g-dev \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /build
CMD ["/bin/bash"]
