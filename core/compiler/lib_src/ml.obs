	~#
	#~
	A node in a DecisionTree: either a leaf carrying a boolean prediction, or an
	internal node that branches on a boolean feature (false -> left, true -> right).
	~#
	class TreeNode {
		@is_leaf : Bool;
		@prediction : Bool;
		@feature : Int;
		@left : TreeNode;
		@right : TreeNode;

		New : private (is_leaf : Bool, prediction : Bool, feature : Int) {
			@is_leaf := is_leaf;
			@prediction := prediction;
			@feature := feature;
		}

		#~
		Creates a leaf node.
		@param prediction class the leaf predicts
		@return leaf node
		~#
		function : NewLeaf(prediction : Bool) ~ TreeNode {
			return TreeNode->New(true, prediction, -1);
		}

		#~
		Creates an internal split node.
		@param feature feature index to branch on
		@return internal node
		~#
		function : NewInternal(feature : Int) ~ TreeNode {
			return TreeNode->New(false, false, feature);
		}

		method : public : IsLeaf() ~ Bool { return @is_leaf; }
		method : public : GetPrediction() ~ Bool { return @prediction; }
		method : public : GetFeature() ~ Int { return @feature; }
		method : public : GetLeft() ~ TreeNode { return @left; }
		method : public : GetRight() ~ TreeNode { return @right; }
		method : public : SetLeft(n : TreeNode) ~ Nil { @left := n; }
		method : public : SetRight(n : TreeNode) ~ Nil { @right := n; }
	}

	class DecisionTree {
		@root : TreeNode;
		@max_depth : Int;
		@min_samples : Int;

		#~
		Creates an (unfitted) decision tree classifier.
		@param max_depth maximum tree depth
		@param min_samples minimum samples required to split a node

```
tree := DecisionTree->New(4, 1);
```
		~#
		New(max_depth : Int, min_samples : Int) {
			@max_depth := max_depth;
			@min_samples := min_samples;
		}

		New : private (max_depth : Int, min_samples : Int, root : TreeNode) {
			@max_depth := max_depth;
			@min_samples := min_samples;
			@root := root;
		}

		#~
		Fits a real recursive binary tree to boolean training data. Each row is a
		set of boolean features with the class label in the LAST column. Nodes
		branch on the feature with the lowest weighted Gini impurity and stop at
		max_depth, min_samples, or a pure node (leaf = majority class).
		@param input training matrix (features..., label) of Bool

```
data := [
  [false, false, false],
  [false, true,  false],
  [true,  false, false],
  [true,  true,  true]];   # label = f0 AND f1
tree := DecisionTree->New(4, 1);
tree->Fit(data);
tree->Predict([true, true])->PrintLine();   # true
```
		~#
		method : public : Fit(input : Bool[,]) ~ Nil {
			@root := BuildNode(input, 0);
		}

		#~
		Predicts the class for a single feature row by walking the tree.
		@param row feature values (trailing label column, if present, is ignored)
		@return predicted class
		~#
		method : public : Predict(row : Bool[]) ~ Bool {
			node := @root;
			while(node <> Nil) {
				if(node->IsLeaf()) {
					return node->GetPrediction();
				};

				f := node->GetFeature();
				if(row[f]) {
					node := node->GetRight();
				}
				else {
					node := node->GetLeft();
				};
			};

			return false;
		}

		#~
		Predicts classes for every row of an input matrix.
		@param input matrix of feature rows (a trailing label column is ignored)
		@return per-row predictions
		~#
		method : public : PredictAll(input : Bool[,]) ~ Bool[] {
			dims := input->Size();
			rows := dims[0];
			cols := dims[1];

			result := Bool->New[rows];
			each(r : rows) {
				row := Bool->New[cols];
				each(c : cols) {
					row[c] := input[r, c];
				};
				result[r] := Predict(row);
			};

			return result;
		}

		#~
		Computes classification accuracy on labeled data, comparing predictions
		against the class label in the LAST column.
		@param input labeled matrix (features..., label) of Bool
		@return fraction of correctly classified rows, or 0.0 if not fitted
		~#
		method : public : Score(input : Bool[,]) ~ Float {
			if(<>IsFitted() | input = Nil) {
				return 0.0;
			};

			dims := input->Size();
			rows := dims[0];
			cols := dims[1];
			if(rows = 0 | cols < 2) {
				return 0.0;
			};

			preds := PredictAll(input);
			correct := 0;
			each(i : rows) {
				if(preds[i] = input[i, cols - 1]) {
					correct += 1;
				};
			};

			return correct->As(Float) / rows->As(Float);
		}

		#~
		Whether the tree has been fitted.
		@return true if fitted
		~#
		method : public : IsFitted() ~ Bool {
			return @root <> Nil;
		}

		#~
		Saves the fitted tree to a file.
		@param filename file to store to
		@return true if successful, false otherwise
		~#
		method : public : Store(filename : String) ~ Bool {
			if(<>IsFitted()) {
				return false;
			};

			serializer := System.IO.Serializer->New();
			WriteTo(serializer);
			return System.IO.Filesystem.FileWriter->WriteFile(filename, serializer->Serialize());
		}

		#~
		Loads a fitted tree from a file.
		@param filename file to load from
		@return fitted tree, or Nil on failure
		~#
		function : Load(filename : String) ~ DecisionTree {
			data := System.IO.Filesystem.FileReader->ReadBinaryFile(filename);
			if(data = Nil) {
				return Nil;
			};

			return ReadFrom(System.IO.Deserializer->New(data));
		}

		#~
		Serializes the tree (hyperparameters + nodes in pre-order) onto an existing
		serializer; used by Store and by ensembles that embed trees (RandomForest).
		@param serializer destination serializer
		~#
		method : public : WriteTo(serializer : System.IO.Serializer) ~ Nil {
			serializer->Write(@max_depth);
			serializer->Write(@min_samples);
			WriteNode(serializer, @root);
		}

		#~
		Reads a tree previously written with WriteTo from a deserializer.
		@param deserializer source deserializer
		@return fitted tree, or Nil on failure
		~#
		function : ReadFrom(deserializer : System.IO.Deserializer) ~ DecisionTree {
			max_depth := deserializer->ReadInt();
			min_samples := deserializer->ReadInt();

			root := ReadNode(deserializer);
			if(root = Nil) {
				return Nil;
			};

			return DecisionTree->New(max_depth, min_samples, root);
		}

		# Pre-order node serialization: leaf flag, then prediction (leaf) or
		# feature index + left/right subtrees (internal). Internal nodes always
		# have both children (see BuildNode).
		method : WriteNode(serializer : System.IO.Serializer, node : TreeNode) ~ Nil {
			if(node->IsLeaf()) {
				serializer->Write(1);
				if(node->GetPrediction()) {
					serializer->Write(1);
				}
				else {
					serializer->Write(0);
				};
			}
			else {
				serializer->Write(0);
				serializer->Write(node->GetFeature());
				WriteNode(serializer, node->GetLeft());
				WriteNode(serializer, node->GetRight());
			};
		}

		function : ReadNode(deserializer : System.IO.Deserializer) ~ TreeNode {
			is_leaf := deserializer->ReadInt();
			if(is_leaf = 1) {
				return TreeNode->NewLeaf(deserializer->ReadInt() = 1);
			};

			node := TreeNode->NewInternal(deserializer->ReadInt());

			left := ReadNode(deserializer);
			right := ReadNode(deserializer);
			if(left = Nil | right = Nil) {
				return Nil;
			};

			node->SetLeft(left);
			node->SetRight(right);
			return node;
		}

		# Recursively builds a tree node from a data subset.
		method : BuildNode(data : Bool[,], depth : Int) ~ TreeNode {
			dims := data->Size();
			rows := dims[0];
			cols := dims[1];
			target_col := cols - 1;

			majority := MajorityClass(data);
			if(rows <= @min_samples | depth >= @max_depth | IsPure(data)) {
				return TreeNode->NewLeaf(majority);
			};

			best_imp := 1000000.0;
			best_feature := -1;
			for(f := 0; f < target_col; f += 1;) {
				imp := SplitImpurity(data, f);
				if(imp < best_imp) {
					best_imp := imp;
					best_feature := f;
				};
			};

			if(best_feature < 0 | best_imp >= 1000000.0) {
				return TreeNode->NewLeaf(majority);
			};

			left_data := SubsetOn(data, best_feature, false);
			right_data := SubsetOn(data, best_feature, true);
			left_dims := left_data->Size();
			right_dims := right_data->Size();
			if(left_dims[0] = 0 | right_dims[0] = 0) {
				return TreeNode->NewLeaf(majority);
			};

			node := TreeNode->NewInternal(best_feature);
			node->SetLeft(BuildNode(left_data, depth + 1));
			node->SetRight(BuildNode(right_data, depth + 1));
			return node;
		}

		# Returns the subset of rows whose `feature` column equals `want`.
		method : SubsetOn(data : Bool[,], feature : Int, want : Bool) ~ Bool[,] {
			dims := data->Size();
			rows := dims[0];
			cols := dims[1];

			cnt := 0;
			each(r : rows) {
				if(data[r, feature] = want) {
					cnt += 1;
				};
			};

			out := Bool->New[cnt, cols];
			idx := 0;
			each(r : rows) {
				if(data[r, feature] = want) {
					each(c : cols) {
						out[idx, c] := data[r, c];
					};
					idx += 1;
				};
			};

			return out;
		}

		# Majority class label in the data (ties resolve to true).
		method : MajorityClass(data : Bool[,]) ~ Bool {
			dims := data->Size();
			rows := dims[0];
			cols := dims[1];
			target_col := cols - 1;

			pos := 0;
			each(r : rows) {
				if(data[r, target_col]) {
					pos += 1;
				};
			};

			return pos * 2 >= rows;
		}

		# Whether every row shares the same label.
		method : IsPure(data : Bool[,]) ~ Bool {
			dims := data->Size();
			rows := dims[0];
			cols := dims[1];
			if(rows = 0) {
				return true;
			};
			target_col := cols - 1;

			first := data[0, target_col];
			each(r : rows) {
				if(data[r, target_col] <> first) {
					return false;
				};
			};

			return true;
		}

		# Weighted Gini impurity of splitting `data` on `feature`. Returns a large
		# sentinel when the feature does not actually partition the rows (so it is
		# never selected); a perfect split correctly yields 0.0 (the minimum).
		method : SplitImpurity(data : Bool[,], feature : Int) ~ Float {
			left := SubsetOn(data, feature, false);
			right := SubsetOn(data, feature, true);

			left_dims := left->Size();
			right_dims := right->Size();
			ln := left_dims[0];
			rn := right_dims[0];
			if(ln = 0 | rn = 0) {
				return 1000000.0;
			};

			n := (ln + rn)->As(Float);
			return (ln->As(Float) / n) * GiniOf(left) + (rn->As(Float) / n) * GiniOf(right);
		}

		# Gini impurity of a data subset based on its label (last) column.
		method : GiniOf(data : Bool[,]) ~ Float {
			dims := data->Size();
			rows := dims[0];
			cols := dims[1];
			if(rows = 0) {
				return 0.0;
			};
			target_col := cols - 1;

			pos := 0;
			each(r : rows) {
				if(data[r, target_col]) {
					pos += 1;
				};
			};

			p := pos->As(Float) / rows->As(Float);
			return 1.0 - (p * p + (1.0 - p) * (1.0 - p));
		}

		#~
		Splits a matrix based on a list of decisions
		@param decisions list of decisions
		@param input matrix to be split
		@return split matrix
		~#
		function : native : Query(decisions : Vector<Split>, input : Bool[,]) ~ Bool[,] {
			each(decision := decisions) {
				out := Split(decision->GetIndex(), input);
				if(out = Nil) {
					return input;
				};
				input := out;
			}

			return input;
		}

		#~
		Calculates a list of decision splits
		@param input training matrix
		@return list of decision tree splits
		~#
		function : native : Train(input : Bool[,]) ~ Vector<Split> {					
			decisions := Vector->New()<Split>;
			dims := input->Size();
			
			cols := dims[1] - 1;
			if(cols > 0) {
				done := false;
				while(<>done) {
					best_wgi := 1000000.0;
					best_index := -1;

					each(i : cols) {
						wgi := WeightedGini(i, cols, input);
						if(wgi <> 0.0 & wgi < best_wgi) {
							best_wgi := wgi;
							best_index := i;
						}
					}

					if(best_index > - 1) {
						input := Split(best_index, input);
						decisions->AddBack(Split->New(best_index, best_wgi));

					}
					else {
						done := true;
					};
				};
			};

			return decisions;
		}

		#~
		Splits a matrix along the given column
		@param index index used to split
		@param input matrix to split
		@return split matrix
		~#
		function : native : Split(index : Int, input : Bool[,]) ~ Bool[,] {
			split_len := Matches(index, input);
			if(split_len > 0) {
				dims := input->Size();
				rows := dims[0];
				cols := dims[1];

				out := Bool->New[split_len, cols];
				count := 0;
				if(index > -1 & index < cols) {
					each(row : rows) {
						if(input[row, index]) {
							each(k : cols) {
								out[count, k] := input[row, k];
							};
							count += 1;
						};
					};
				};

				return out;
			};

			return Nil;
		}

		#~
		Calculates the Gini index
		@param acheived number acheived
		@param goal achievement target
		@return Gini index
		~#
		function : native : Gini(acheived : Float, goal : Float) ~ Float {
			reached := acheived / goal;
			not_reached := (goal - acheived) / goal;
			return 1 - (reached*reached + not_reached*not_reached);
		}

		function : native : WeightedGini(test : Int, target : Int, input : Bool[,]) ~ Float {
			wgi := 0.0;

			dims := input->Size();
			size := dims[0]->As(Float);

			# left
			goal := Matches(test, input);
			if(goal > 0.0) {
				wgi += goal / size * Gini(Acheived(test, target, input), goal);
			}
			else {
				return 0.0;
			};

			
			# right
			goal := Mismatches(test, input);
			if(goal > 0.0) {
				wgi += goal / size * Gini(Unacheived(test, target, input), goal);
			}
			else {
				return 0.0;
			};

			return wgi;
		}

		#~
		Count matches in a column
		@param index column index
		@param matrix matrix matrix to inspect
		@return number of matches
		~#
		function : Matches(index : Int, matrix : Bool[,]) ~ Int {
			dims := matrix->Size();
			rows := dims[0];

			count := 0;
			if(index > -1 & index < rows) {
				each(row : rows) {
					if(matrix[row, index]) {
						count += 1;
					};
				};
			};

			return count;
		}

		#~
		Count mismatches in a column
		@param index column index
		@param matrix matrix matrix to inspect
		@return number of mismatches
		~#
		function : Mismatches(index : Int, matrix : Bool[,]) ~ Int {
			dims := matrix->Size();
			rows := dims[0];

			count := 0;
			if(index > -1 & index < rows) {
				each(row : rows) {
					if(matrix[row, index] = false) {
						count += 1;
					};
				};
			};

			return count;
		}

		function : native : Acheived(test_index : Int, goal_index : Int, matrix : Bool[,]) ~ Float {
			dims := matrix->Size();
			rows := dims[0];

			count := 0;
			if(test_index > -1 & test_index < rows & goal_index > -1 & goal_index < rows) {
				each(row : rows) {
					if(matrix[row, test_index] & matrix[row, goal_index]) {
						count += 1;
					};
				};
			};

			return count;
		}

		function : native : Unacheived(test_index : Int, goal_index : Int, matrix : Bool[,]) ~ Float {
			dims := matrix->Size();
			rows := dims[0];

			count := 0;
			if(test_index > -1 & test_index < rows & goal_index > -1 & goal_index < rows) {
				each(row : rows) {
					if(matrix[row, test_index] = false & matrix[row, goal_index]) {
						count += 1;
					};
				};
			};

			return count;
		}

		#~
		Loads a boolean input matrix from a CSV file of 1s and 0s
		@param filename CSV file to load
		@return boolean matrix
		~#
		function : LoadCsv(filename : String) ~ Bool[,] {
			table := CsvTable->New(System.IO.Filesystem.FileReader->ReadFile(filename));
			if(table->IsParsed()) {
				row_size := table->Size();
				if(row_size->Size() > 1) {
					column := table->Get(1);
					column_size := column->Size();

					matrix := Bool->New[row_size - 1, column_size];
					for(i := 1; i < row_size; i += 1;) {
						each(j : column_size) {
							value := table->Get(i)->Get(j)->ToLower();
							if(value->Equals(["0", "0.0", "false", "o", "f"])) {
								matrix[i - 1, j] := false;
							}
							else {
								matrix[i - 1, j] := true;	
							};
						};
					};

					return matrix;
				};
			};

			return Nil;
		}
	}

	class Split {
		@index : Int;
		@weighted_gini : Float;
		
		New(index : Int, weighted_gini : Float) {
			@index := index;
			@weighted_gini := weighted_gini;
		}

		method : public : GetWeightedGini() ~ Float {
			return @weighted_gini;
		}

		method : public : GetIndex() ~ Int {
			return @index;
		}

		method : public : ToString() ~ String {
			return "index={$@index},weighted_gini={$@weighted_gini}";
		}
	}
	
	#~
	Naive Bayes entry of term with counts
	~#
	class BayesEntry {
		@name : String;
		@count : Int;
		@bayes : Float;

		#~
		Constructor
		@param name entry name
		@param count count of occurrences 
		~#
		New(name : String, count : Int) {
			@name := name;
			@count := count;
		}

		#~
		Get the entry name
		@return entry name
		~#
		method : public : GetName() ~ String {
			return @name;
		}

		#~
		Get the entry count
		@return entry count
		~#
		method : public : GetCount() ~ Int {
			return @count;
		}

		#~
		Set the entry count
		@param count entry count
		~#
		method : public : SetCount(count : Int) ~ Nil {
			@count := count;
		}
	}

	#~
	Naive Bayes group of entries
	~#
	class BayesGroup {
		@entries : Map<String, BayesEntry>;
		@prob : Float;

		#~
		Sets the initial probability
		@param prob initial probability
		~#
		New(prob : Float) {
			@prob := prob;
			@entries := Map->New()<String, BayesEntry>;
		}

		#~
		Adds an entry
		@param entry entry to add
		@return true if added, false otherwise
		~#
		method : public : AddEntry(entry : BayesEntry) ~ Bool {
			if(@entries->Has(entry->GetName())) {
				return false;
			};

			@entries->Insert(entry->GetName(), entry);
			return true;
		}

		#~
		Gets entries
		@return entries
		~#
		method : public : GetEntries() ~ Map<String, BayesEntry> {
			return @entries;
		}

		#~
		Gets the initial probability
		@return probability
		~#
		method : public : GetProbability() ~ Float {
			return @prob;
		}
	}

	#~
	Naive Bayes ML algorithm

```
normal := BayesGroup->New(8.0 / 12.0);
normal->AddEntry(BayesEntry->New("dear", 8));		
normal->AddEntry(BayesEntry->New("friend", 5));
normal->AddEntry(BayesEntry->New("lunch", 3));
normal->AddEntry(BayesEntry->New("money", 1));

spam := BayesGroup->New(4.0 / 12.0);
spam->AddEntry(BayesEntry->New("dear", 2));
spam->AddEntry(BayesEntry->New("friend", 1));
spam->AddEntry(BayesEntry->New("lunch", 0));
spam->AddEntry(BayesEntry->New("money", 4));

bayes := NaiveBayes->New(normal, spam);
finding := bayes->Query(["lunch", "money", "money", "money", "money"]);

if(finding = 0) {
  "normal"->PrintLine();
}
else if(finding = 1) {
  "spam"->PrintLine();	
}
else {
  "invalid"->PrintLine();	
}	
	```
	~#
	class NaiveBayes {
		@left : BayesGroup;
		@right : BayesGroup;

		#~
		Constructor
		@param left left group
		@param right right group
		~#
		New(left : BayesGroup, right : BayesGroup) {
			@left := left;
			@right := right;
		}

		#~
		Query to Naive Bayes
		@param terms list of term to calculate
		@return 0 if left, 1 if right, -1 otherwise
		~#
		method : public : Query(terms : String[]) ~ Int {
			if(terms = Nil | terms->Size() = 0) {
				return -1;
			};

			# Log-space scores (higher = more likely); compare directly
			left := Query(terms, @left);
			right := Query(terms, @right);

			if(left >= right) {
				return 0;
			};

			return 1;
		}

		#~
		Computes the Laplace-smoothed log-probability that the given terms belong
		to the supplied group. Likelihoods are summed in log space to avoid
		floating-point underflow on long term lists, and the group's counts are
		never mutated (so queries are side-effect free and repeatable).
		@param terms observed terms
		@param group class group to score against
		@return log-probability score (higher is more likely)
		~#
		method : Query(terms : String[], group : BayesGroup) ~ Float {
			entries := group->GetEntries();
			prior := group->GetProbability();
			values := entries->GetValues()<BayesEntry>;

			vocab := values->Size()->As(Float);
			total := 0.0;
			each(value := values) {
				total += value->GetCount();
			};

			# Sum log-likelihoods with add-one (Laplace) smoothing
			log_prob := prior->Log();
			each(term := terms) {
				find := entries->Find(term);
				count := 0.0;
				if(find <> Nil) {
					count := find->GetCount()->As(Float);
				};
				likelihood := (count + 1.0) / (total + vocab);
				log_prob += likelihood->Log();
			};

			return log_prob;
		}
	}

	#~
	K-Nearest Neighbors algorithm

```
matrix := [
  [51.0,  167.0]
  [58.0, 169.0]
  [62.0, 182.0]
  [69.0, 176.0]
  [64.0, 173.0]
  [65.0, 172.0]
  [56.0, 174.0]
  [57.0, 173.0]
  [55.0, 170.0]];

labels := [
  "underweight", 
  "normal", 
  "normal", 
  "normal", 
  "normal", 
  "underweight", 
  "normal", 
  "normal", 
  "normal"];

knn := KNearestNeighbors->New(matrix, labels);
nearest := knn->Query(3, [57.0, 170.0]);
each(neighbor := nearest) {
  neighbor->ToString()->PrintLine();
};
```
~#
	#~
	A node in a KDTree: the row it holds, the dimension it splits on, and the
	child subtrees.
	~#
	class : private : KDNode {
		@row : Int;
		@dim : Int;
		@left : KDNode;
		@right : KDNode;

		New(row : Int, dim : Int) {
			@row := row;
			@dim := dim;
		}

		method : public : GetRow() ~ Int { return @row; }
		method : public : GetDim() ~ Int { return @dim; }
		method : public : GetLeft() ~ KDNode { return @left; }
		method : public : GetRight() ~ KDNode { return @right; }
		method : public : SetLeft(n : KDNode) ~ Nil { @left := n; }
		method : public : SetRight(n : KDNode) ~ Nil { @right := n; }
	}

	#~
	K-d tree for fast exact nearest-neighbor queries over numeric rows.
	Built by median splits cycling through the dimensions; queries prune
	subtrees whose splitting plane lies farther than the current k-th best
	distance. Equivalent results to a brute-force scan (Euclidean).

```
tree := KDTree->New(matrix);
nearest := tree->Nearest(3, [57.0, 170.0]);   # row indexes, closest first
```
	~#
	class KDTree {
		@data : Float[,];
		@root : KDNode;
		@size : Int;
		@cols : Int;

		#~
		Builds the tree from a data matrix.
		@param data matrix (rows=samples, cols=features)
		~#
		New(data : Float[,]) {
			@data := data;
			if(data <> Nil) {
				dims := data->Size();
				@size := dims[0];
				@cols := dims[1];

				if(@size > 0 & @cols > 0) {
					indexes := Int->New[@size];
					each(i : @size) {
						indexes[i] := i;
					};
					@root := Build(indexes, 0, @size - 1, 0);
				};
			};
		}

		# Builds a subtree over indexes[lo..hi] splitting on depth % cols.
		method : Build(indexes : Int[], lo : Int, hi : Int, depth : Int) ~ KDNode {
			if(lo > hi) {
				return Nil;
			};

			dim := depth % @cols;
			SortByDim(indexes, lo, hi, dim);
			mid := lo + (hi - lo) / 2;

			node := KDNode->New(indexes[mid], dim);
			node->SetLeft(Build(indexes, lo, mid - 1, depth + 1));
			node->SetRight(Build(indexes, mid + 1, hi, depth + 1));
			return node;
		}

		# In-place quicksort of indexes[lo..hi] by the dim-th coordinate.
		method : SortByDim(indexes : Int[], lo : Int, hi : Int, dim : Int) ~ Nil {
			if(lo >= hi) {
				return;
			};

			pivot := @data[indexes[lo + (hi - lo) / 2], dim];
			i := lo;
			j := hi;
			while(i <= j) {
				while(@data[indexes[i], dim] < pivot) {
					i += 1;
				};
				while(@data[indexes[j], dim] > pivot) {
					j -= 1;
				};
				if(i <= j) {
					tmp := indexes[i];
					indexes[i] := indexes[j];
					indexes[j] := tmp;
					i += 1;
					j -= 1;
				};
			};

			SortByDim(indexes, lo, j, dim);
			SortByDim(indexes, i, hi, dim);
		}

		#~
		Finds the k nearest rows to the query point.
		@param k number of neighbors
		@param query query point (length = features)
		@return row indexes sorted closest-first (fewer than k when the tree is smaller), or Nil on invalid input
		~#
		method : public : Nearest(k : Int, query : Float[]) ~ Int[] {
			if(@root = Nil | query = Nil | k < 1 | query->Size() <> @cols) {
				return Nil;
			};

			count := k;
			if(count > @size) {
				count := @size;
			};

			# best-so-far lists, sorted ascending by distance
			best_rows := Int->New[count];
			best_dists := Float->New[count];
			each(i : count) {
				best_dists[i] := Float->Inf();
			};

			Search(@root, query, best_rows, best_dists, count);

			return best_rows;
		}

		method : Search(node : KDNode, query : Float[], best_rows : Int[], best_dists : Float[], count : Int) ~ Nil {
			if(node = Nil) {
				return;
			};

			row := node->GetRow();
			dist_sq := 0.0;
			each(j : @cols) {
				diff := query[j] - @data[row,j];
				dist_sq += diff * diff;
			};

			# insert into the sorted best list if it beats the current worst
			if(dist_sq < best_dists[count - 1]) {
				pos := count - 1;
				while(pos > 0 & best_dists[pos - 1] > dist_sq) {
					best_dists[pos] := best_dists[pos - 1];
					best_rows[pos] := best_rows[pos - 1];
					pos -= 1;
				};
				best_dists[pos] := dist_sq;
				best_rows[pos] := row;
			};

			dim := node->GetDim();
			delta := query[dim] - @data[row,dim];

			near : KDNode;
			far : KDNode;
			if(delta < 0.0) {
				near := node->GetLeft();
				far := node->GetRight();
			}
			else {
				near := node->GetRight();
				far := node->GetLeft();
			};

			Search(near, query, best_rows, best_dists, count);

			# the far side can only matter when the splitting plane is closer
			# than the current k-th best distance
			if(delta * delta < best_dists[count - 1]) {
				Search(far, query, best_rows, best_dists, count);
			};
		}

		#~
		Gets the number of rows indexed.
		@return row count
		~#
		method : public : Size() ~ Int {
			return @size;
		}
	}

	class KNearestNeighbors {
		@matrix : Float[,];
		@labels : String[];

		#~
		Constructor.
		@param matrix matrix input matrix
		@param labels categories labels
		~#
		New(matrix : Float[,], labels : String[]) {
			@matrix := matrix;
			@labels := labels;
		}

		#~
		Query the matrix for classification
		@param k number of nearest neighbors 
		@param query input query
		@return k nearest neighbors 
		~#
		method : public : Query(k : Int, query : Float[]) ~ KNeighbor[] {
			return Query(query, k);
		}

		#~
		Classifies a query point by majority vote of its k nearest neighbors.
		Ties are broken in favor of the label that first reaches the top count.
		@param k number of neighbors to poll
		@param query input feature vector
		@return predicted category label (empty string if there are no neighbors)

```
knn := KNearestNeighbors->New(matrix, labels);
knn->Classify(3, [57.0, 170.0])->PrintLine();
```
		~#
		method : public : Classify(k : Int, query : Float[]) ~ String {
			neighbors := Query(k, query);
			if(neighbors = Nil | neighbors->Size() = 0) {
				return "";
			};

			best_label := "";
			best_count := -1;
			for(i := 0; i < neighbors->Size(); i += 1;) {
				neighbor := neighbors[i];
				cat := neighbor->GetCategory();

				count := 0;
				for(j := 0; j < neighbors->Size(); j += 1;) {
					peer := neighbors[j];
					if(peer->GetCategory()->Equals(cat)) {
						count += 1;
					};
				};

				if(count > best_count) {
					best_count := count;
					best_label := cat;
				};
			};

			return best_label;
		}

		method : native : Query(query : Float[], k : Int) ~ KNeighbor[] {
			dims := @matrix->Size();
			rows := dims[0];
			cols := dims[1];

			distances := Collection.CompareVector->New()<KNeighbor>;
			row := Float->New[cols];	
			each(i : rows) {
				each(j : cols) {
					row[j] := @matrix[i,j];
				};
				dist := EuclideanDistance(row, query);
				distances->AddBack(KNeighbor->New(dist, i, @labels[i]));
			};

			# Ascending by distance: nearest neighbors first
			distances->Sort();
			if(k > distances->Size()) {
				k := distances->Size();
			};

			results := KNeighbor->New[k];
			each(i : k) {
				results[i] := distances->Get(i);
			};

			return results;
		}

		method : native : EuclideanDistance(a : Float[], b : Float[]) ~ Float {
			if(a->Size() <> b->Size()) {
				return 0.0;
			};

			total := 0.0;
			
			each(i : a) {
				diff := b[i] - a[i];
				total += diff * diff;
			};

			return total->Sqrt();
		}
	}

	#~
	K-Neighbor result
	~#
	class KNeighbor implements Compare {
		@dist : Float;
		@row : Int;
		@cat : String;

		#~
		Constructor.
		@param dist distance value
		@param row row index
		@param cat category label
		~#
		New(dist : Float, row : Int, cat : String) {
			@dist := dist;
			@row := row;
			@cat := cat;
		}

		#~
		Compares neighbors 
		@param rhs neighbor to compare
		@return 0 if equal, -1 if types differ, 1 if equal
		~#
		method : public : Compare(rhs:System.Compare) ~ Int {
			if(@self->GetClassID() <> rhs->GetClassID()) {
				return -1;
			};
			right : KNeighbor := rhs->As(KNeighbor);
			bar := right->GetDistance();
			# foo := Float->Compare(bar, @dist);

			if(@dist < bar) {
				return -1;
			}
			else if(@dist > bar) {
				return 1;
			};

			return 0;
		}

		#~
		Returns a unique hash ID for a boolean
		@return hash ID
		~#
		method : public : HashID() ~ Int {
			return @dist * 4000000;
		}

		#~
		Get the distance
		@return distance
		~#
		method : public : GetDistance() ~ Float {
			return @dist;
		}

		#~
		Get the row index
		@return row index
		~#
		method : public : GetRow() ~ Int {
			return @row;
		}

		#~
		Get the category label
		@return category label
		~#
		method : public : GetCategory() ~ String {
			return @cat;
		}

		#~
		Returns a string representation of the neighbor
		@return string representation of the neighbor
		~#
		method : public : ToString() ~ String {
			return "{$@row}: distance={$@dist}, category={$@cat}";
		}
	}

#~
	K-Means clustering algorithm
	
	```
records->AddBack(FloatArrayRef->New([9.677901811, 3.044481052]));
records->AddBack(FloatArrayRef->New([2.103293937, 2.446154204]));
records->AddBack(FloatArrayRef->New([9.340432657, 2.896683906]));
records->AddBack(FloatArrayRef->New([7.674354483, 4.765027229]));
records->AddBack(FloatArrayRef->New([8.656404515, 0.481807722]));
# ...

labels := ["group-a","group-b", "group-c"];
groups := KMeans->Group(labels, records, 2, 0.0, 10.0);
groups->GetGroupNames()->ToString()->PrintLine();

groups->GetDunnIndex()->PrintLine();

each(group in groups) {
  group->GetName()->PrintLine();
  group->GetArrayValue(0)->PrintLine();
}
	```
~#
	class KMeans {
		@debug : static : Bool;

		#~
		K-Means group clustering
		@param group_labels group labels used to tag groups also specify K
		@param records input records
		@param record_length length of records, all records lengths be the same
		@param min_value smallest record value
		@param max_value largest record value
		@return labeled grouping
		~#
		function : native : Group(group_labels : String[], records : Vector<FloatArrayRef>, record_length : Int, min_value : Float, max_value : Float) ~ KMeansGrouping {
			return Group(group_labels, records, record_length, min_value, max_value, 100, 1);
		}

		#~
		K-Means clustering with k-means++ seeding (deterministic for a given seed),
		an iteration cap, and explicit empty-cluster handling.
		@param group_labels group labels; the count determines K
		@param records input records (all of equal length)
		@param record_length length of each record
		@param min_value smallest record value (kept for API compatibility)
		@param max_value largest record value (kept for API compatibility)
		@param max_iterations hard cap on refinement iterations
		@param seed PRNG seed for reproducible k-means++ initialization
		@return labeled grouping
		~#
		function : native : Group(group_labels : String[], records : Vector<FloatArrayRef>, record_length : Int, min_value : Float, max_value : Float, max_iterations : Int, seed : Int) ~ KMeansGrouping {
			rand := Random->New(seed);
			k := group_labels->Size();
			centroids := KMeansPlusPlus(k, records, rand);
			updated_centroids := FloatArrayRef->New[k];

			groups := Hash->New()<String, Vector<FloatArrayRef>>;
			each(centroid_label in group_labels) {
				groups->Insert(centroid_label, Vector->New()<FloatArrayRef>);
			};

			iter := 0;
			has_changed := true;
			while(has_changed & iter < max_iterations) {
				iter += 1;

				each(datum in records) {
					shortest_index := -1;
					shortest_distance := Float->Inf();

					each(i : centroids) {
						centroid := centroids[i];
						distance := Distance(datum, centroid);
						if(distance < shortest_distance) {
							shortest_distance := distance;
							shortest_index := i;
						};
					};

					nearest_centroid_label := group_labels[shortest_index];
					group := groups->Find(nearest_centroid_label)<FloatArrayRef>;
					group->AddBack(datum);
				};

				group_key_values := groups->GetKeyValues()<Pair<String, Vector<FloatArrayRef>>>;
				each(i : group_key_values) {
					group_key_value := group_key_values->Get(i);
					group := group_key_value->GetSecond();

					update := Average(group, record_length);
					if(update <> Nil) {
						updated_centroids[i] := update;
					}
					else {
						# empty cluster: retain its previous centroid
						updated_centroids[i] := centroids[i];
					};
				};

				has_changed := HasChanged(centroids, updated_centroids);
				if(has_changed) {
					centroids := updated_centroids;
					updated_centroids := FloatArrayRef->New[k];

					each(centroid_label in group_labels) {
						if(groups->Remove(centroid_label)) {
							groups->Insert(centroid_label, Vector->New()<FloatArrayRef>);
						};
					};
				};
			};

			return KMeansGrouping->New(groups);
		}

		# k-means++ seeding: the first center is a uniformly random record; each
		# subsequent center is chosen with probability proportional to the squared
		# distance from the nearest already-chosen center. Deterministic given rand.
		function : native : KMeansPlusPlus(k : Int, records : Vector<FloatArrayRef>, rand : Random) ~ FloatArrayRef[] {
			centroids := FloatArrayRef->New[k];
			n := records->Size();
			if(n = 0 | k = 0) {
				return centroids;
			};

			first := rand->NextInt(n);
			centroids[0] := records->Get(first);

			chosen := 1;
			while(chosen < k) {
				dists := Float->New[n];
				total := 0.0;
				for(i := 0; i < n; i += 1;) {
					datum := records->Get(i);
					best := Float->Inf();
					for(c := 0; c < chosen; c += 1;) {
						d := Distance(datum, centroids[c]);
						if(d < best) {
							best := d;
						};
					};
					dd := best * best;
					dists[i] := dd;
					total += dd;
				};

				target := rand->NextReal() * total;
				cum := 0.0;
				pick := n - 1;
				picked := false;
				for(i := 0; i < n; i += 1;) {
					cum += dists[i];
					if(<>picked & cum >= target) {
						pick := i;
						picked := true;
					};
				};

				centroids[chosen] := records->Get(pick);
				chosen += 1;
			};

			return centroids;
		}

		function : native : HasChanged(old_centroids : FloatArrayRef[], new_centroids : FloatArrayRef[]) ~ Bool {
			if(old_centroids = Nil | new_centroids = Nil) {
				return false;
			};

			# Converged when every centroid coordinate moved less than the tolerance.
			# Returns true as soon as any coordinate moved at least `tolerance`.
			tolerance := 0.001;
			each(i : old_centroids) {
				a := old_centroids[i];
				b := new_centroids[i];
				if(a = Nil | b = Nil) {
					return false;
				};
				a_values := a->Get();
				b_values := b->Get();

				each(j : a_values) {
					if(Float->Abs(a_values[j] - b_values[j]) >= tolerance) {
						return true;
					};
				};
			};

			return false;
		}

		function : native : Average(group : Vector<FloatArrayRef>, record_length : Int) ~FloatArrayRef {
			if(group->IsEmpty()) {
				return Nil;
			};

			average_values := Float->New[record_length];
			each(i : average_values) {
				sum := 0.0;
				each(array in group) {
					array_values := array->Get();
					sum += array_values[i];
				};
				average := sum / group->Size()->As(Float);
				average_values[i] := average;
			}

			return FloatArrayRef->New(average_values);
		}

		function : native : Distance(left : FloatArrayRef, right : FloatArrayRef) ~ Float {
			if(left = Nil | right = Nil) {
				return 0.0;
			};

			left_values := left->Get(); right_values := right->Get();
			if(left_values->Size() <> right_values->Size()) {
				return 0.0;
			};

			distance := 0.0;
	        each(i : left_values) {
	            distance += Float->Pow(left_values[i] - right_values[i], 2.0);
	        };

	        return distance->Sqrt();
		}
	}

	#~
	Density-based spatial clustering (DBSCAN). Groups points that are densely
	packed (at least min_points neighbors within eps, Euclidean) and labels
	sparse points as noise (-1). Unlike KMeans the cluster count is discovered,
	clusters may be any shape, and the result is deterministic for a given
	input order.

```
scanner := DBSCAN->New(1.0, 3);
scanner->Fit(X);
labels := scanner->GetLabels();   # cluster id per row; -1 = noise
```
	~#
	class DBSCAN {
		@eps : Float;
		@min_points : Int;
		@labels : Int[];
		@num_clusters : Int;
		@is_fitted : Bool;

		#~
		Constructor
		@param eps neighborhood radius (Euclidean)
		@param min_points minimum neighbors (inclusive of the point itself) for a core point
		~#
		New(eps : Float, min_points : Int) {
			@eps := eps;
			@min_points := min_points;
			@is_fitted := false;
		}

		#~
		Clusters the data. Region growing visits rows in order, so results are
		deterministic for a given input.
		@param X data matrix (rows=samples, cols=features)
		@return true if clustering succeeded
		~#
		method : public : Fit(X : Float[,]) ~ Bool {
			if(X = Nil) {
				return false;
			};

			x_dims := X->Size();
			rows := x_dims[0];
			if(rows = 0) {
				return false;
			};

			# -2 = unvisited, -1 = noise, >= 0 = cluster id
			@labels := Int->New[rows];
			each(i : rows) {
				@labels[i] := -2;
			};

			@num_clusters := 0;
			queue := Int->New[rows];

			each(i : rows) {
				if(@labels[i] = -2) {
					neighbors := RegionQuery(X, i);
					if(neighbors->Size() < @min_points) {
						@labels[i] := -1;
					}
					else {
						# new cluster: grow it breadth-first from the seed.
						# Points are claimed (labeled) when enqueued, so each
						# point enters the queue at most once and the fixed
						# queue of `rows` entries can never overflow.
						cluster := @num_clusters;
						@num_clusters += 1;
						@labels[i] := cluster;

						head := 0;
						tail := 0;
						each(n : neighbors) {
							q := neighbors[n];
							if(@labels[q] = -2 | @labels[q] = -1) {
								@labels[q] := cluster;
								queue[tail] := q;
								tail += 1;
							};
						};

						while(head < tail) {
							p := queue[head];
							head += 1;

							p_neighbors := RegionQuery(X, p);
							if(p_neighbors->Size() >= @min_points) {
								# core point: claim and extend the frontier
								each(n : p_neighbors) {
									q := p_neighbors[n];
									if(@labels[q] = -2 | @labels[q] = -1) {
										@labels[q] := cluster;
										queue[tail] := q;
										tail += 1;
									};
								};
							};
						};
					};
				};
			};

			@is_fitted := true;
			return true;
		}

		# Indexes of all rows within eps of row i (inclusive of i itself).
		method : RegionQuery(X : Float[,], i : Int) ~ Int[] {
			x_dims := X->Size();
			rows := x_dims[0];
			cols := x_dims[1];

			eps_sq := @eps * @eps;
			found := Int->New[rows];
			count := 0;
			each(j : rows) {
				dist_sq := 0.0;
				each(c : cols) {
					diff := X[i,c] - X[j,c];
					dist_sq += diff * diff;
				};

				if(dist_sq <= eps_sq) {
					found[count] := j;
					count += 1;
				};
			};

			result := Int->New[count];
			each(j : count) {
				result[j] := found[j];
			};

			return result;
		}

		#~
		Gets the per-row cluster labels (-1 = noise).
		@return label array, or Nil if not fitted
		~#
		method : public : GetLabels() ~ Int[] {
			return @labels;
		}

		#~
		Gets the number of clusters discovered.
		@return cluster count
		~#
		method : public : GetNumClusters() ~ Int {
			return @num_clusters;
		}

		#~
		Whether the clustering has been run.
		@return true if fitted
		~#
		method : public : IsFitted() ~ Bool {
			return @is_fitted;
		}
	}

	#~
	Gaussian mixture model with diagonal covariance, fitted by expectation-
	maximization. Component means are seeded k-means++-style with the seedable
	System.ML.Random for reproducible fits; the E-step works in the log domain
	for numerical stability and variances are floored. Training stops when the
	average log-likelihood improves by less than the tolerance.

```
gmm := GaussianMixture->New(2, 7);
gmm->Fit(X);
components := gmm->PredictClass(X);     # hard assignments
resp := gmm->Predict(X);                # soft responsibilities
```
	~#
	class GaussianMixture {
		@num_components : Int;
		@max_iterations : Int;
		@tolerance : Float;
		@seed : Int;
		@weights : Float[];
		@means : Float[,];
		@variances : Float[,];
		@log_likelihood : Float;
		@iterations_run : Int;
		@is_fitted : Bool;

		#~
		Constructor with default optimization settings (100 iterations,
		tolerance 0.000001).
		@param num_components number of mixture components
		@param seed PRNG seed for reproducible initialization
		~#
		New(num_components : Int, seed : Int) {
			@num_components := num_components;
			@max_iterations := 100;
			@tolerance := 0.000001;
			@seed := seed;
			@is_fitted := false;
		}

		#~
		Constructor with explicit optimization settings.
		@param num_components number of mixture components
		@param max_iterations EM iteration cap
		@param tolerance stop when average log-likelihood improves less than this
		@param seed PRNG seed for reproducible initialization
		~#
		New(num_components : Int, max_iterations : Int, tolerance : Float, seed : Int) {
			@num_components := num_components;
			@max_iterations := max_iterations;
			@tolerance := tolerance;
			@seed := seed;
			@is_fitted := false;
		}

		New : private (num_components : Int, weights : Float[], means : Float[,], variances : Float[,], log_likelihood : Float) {
			@num_components := num_components;
			@weights := weights;
			@means := means;
			@variances := variances;
			@log_likelihood := log_likelihood;
			@is_fitted := true;
		}

		#~
		Fits the mixture by EM.
		@param X data matrix (rows=samples, cols=features)
		@return true if fitting succeeded
		~#
		method : public : Fit(X : Float[,]) ~ Bool {
			if(X = Nil) {
				return false;
			};

			x_dims := X->Size();
			rows := x_dims[0];
			cols := x_dims[1];
			if(rows < @num_components | @num_components < 1 | cols = 0) {
				return false;
			};

			n := rows->As(Float);

			# global per-feature variance for initialization and flooring
			global_var := Float->New[cols];
			each(j : cols) {
				mean := 0.0;
				each(i : rows) {
					mean += X[i,j];
				};
				mean := mean / n;

				sq := 0.0;
				each(i : rows) {
					diff := X[i,j] - mean;
					sq += diff * diff;
				};
				global_var[j] := sq / n;
				if(global_var[j] < 0.000001) {
					global_var[j] := 0.000001;
				};
			};

			# k-means++-style seeding of the component means
			rand := Random->New(@seed);
			@means := Float->New[@num_components, cols];
			first := rand->NextInt(rows);
			each(j : cols) {
				@means[0,j] := X[first,j];
			};

			chosen := 1;
			while(chosen < @num_components) {
				dists := Float->New[rows];
				total := 0.0;
				each(i : rows) {
					best := Float->Inf();
					each(c : chosen) {
						d := 0.0;
						each(j : cols) {
							diff := X[i,j] - @means[c,j];
							d += diff * diff;
						};
						if(d < best) {
							best := d;
						};
					};
					dists[i] := best;
					total += best;
				};

				target := rand->NextReal() * total;
				cum := 0.0;
				pick := rows - 1;
				picked := false;
				each(i : rows) {
					cum += dists[i];
					if(<>picked & cum >= target) {
						pick := i;
						picked := true;
					};
				};

				each(j : cols) {
					@means[chosen,j] := X[pick,j];
				};
				chosen += 1;
			};

			# uniform weights, global variances
			@weights := Float->New[@num_components];
			@variances := Float->New[@num_components, cols];
			each(c : @num_components) {
				@weights[c] := 1.0 / @num_components->As(Float);
				each(j : cols) {
					@variances[c,j] := global_var[j];
				};
			};

			# EM
			resp := Float->New[rows, @num_components];
			previous_ll := Float->NegInf();
			@iterations_run := 0;

			converged := false;
			each(iter : @max_iterations) {
				if(<>converged) {
					@iterations_run += 1;

					# E-step: responsibilities via log-sum-exp
					ll := 0.0;
					each(i : rows) {
						log_joint := Float->New[@num_components];
						max_log := Float->NegInf();
						each(c : @num_components) {
							log_joint[c] := @weights[c]->Log() + LogGaussian(X, i, c);
							if(log_joint[c] > max_log) {
								max_log := log_joint[c];
							};
						};

						sum_exp := 0.0;
						each(c : @num_components) {
							sum_exp += Float->Exp(log_joint[c] - max_log);
						};
						log_norm := max_log + sum_exp->Log();
						ll += log_norm;

						each(c : @num_components) {
							resp[i,c] := Float->Exp(log_joint[c] - log_norm);
						};
					};
					ll := ll / n;

					# M-step
					each(c : @num_components) {
						resp_sum := 0.0;
						each(i : rows) {
							resp_sum += resp[i,c];
						};

						if(resp_sum < 0.0000000001) {
							resp_sum := 0.0000000001;
						};
						@weights[c] := resp_sum / n;

						each(j : cols) {
							mean := 0.0;
							each(i : rows) {
								mean += resp[i,c] * X[i,j];
							};
							mean := mean / resp_sum;
							@means[c,j] := mean;
						};

						each(j : cols) {
							variance := 0.0;
							each(i : rows) {
								diff := X[i,j] - @means[c,j];
								variance += resp[i,c] * diff * diff;
							};
							variance := variance / resp_sum;
							# floor relative to the global scale
							floor := 0.000001 * global_var[j];
							if(variance < floor) {
								variance := floor;
							};
							@variances[c,j] := variance;
						};
					};

					if(ll - previous_ll < @tolerance & @iterations_run > 1) {
						converged := true;
					};
					previous_ll := ll;
				};
			};

			@log_likelihood := previous_ll;
			@is_fitted := true;
			return true;
		}

		# log N(X[i] | means[c], diag(variances[c]))
		method : LogGaussian(X : Float[,], i : Int, c : Int) ~ Float {
			x_dims := X->Size();
			cols := x_dims[1];

			two_pi := 2.0 * Float->Pi();
			sum := 0.0;
			each(j : cols) {
				variance := @variances[c,j];
				diff := X[i,j] - @means[c,j];
				sum -= 0.5 * ((two_pi * variance)->Log() + diff * diff / variance);
			};

			return sum;
		}

		#~
		Computes soft component responsibilities for every row.
		@param X data matrix
		@return rows x components responsibility matrix, or Nil if not fitted
		~#
		method : public : Predict(X : Float[,]) ~ Float[,] {
			if(<>@is_fitted | X = Nil) {
				return Nil;
			};

			x_dims := X->Size();
			rows := x_dims[0];

			result := Float->New[rows, @num_components];
			each(i : rows) {
				log_joint := Float->New[@num_components];
				max_log := Float->NegInf();
				each(c : @num_components) {
					log_joint[c] := @weights[c]->Log() + LogGaussian(X, i, c);
					if(log_joint[c] > max_log) {
						max_log := log_joint[c];
					};
				};

				sum_exp := 0.0;
				each(c : @num_components) {
					sum_exp += Float->Exp(log_joint[c] - max_log);
				};
				log_norm := max_log + sum_exp->Log();

				each(c : @num_components) {
					result[i,c] := Float->Exp(log_joint[c] - log_norm);
				};
			};

			return result;
		}

		#~
		Predicts the most likely component for every row.
		@param X data matrix
		@return per-row component ids, or Nil if not fitted
		~#
		method : public : PredictClass(X : Float[,]) ~ Int[] {
			resp := Predict(X);
			if(resp = Nil) {
				return Nil;
			};

			resp_dims := resp->Size();
			rows := resp_dims[0];

			result := Int->New[rows];
			each(i : rows) {
				best := 0;
				each(c : @num_components) {
					if(resp[i,c] > resp[i,best]) {
						best := c;
					};
				};
				result[i] := best;
			};

			return result;
		}

		#~
		Gets the fitted component means (components x features).
		@return mean matrix, or Nil if not fitted
		~#
		method : public : GetMeans() ~ Float[,] {
			return @means;
		}

		#~
		Gets the fitted mixture weights.
		@return weight array, or Nil if not fitted
		~#
		method : public : GetWeights() ~ Float[] {
			return @weights;
		}

		#~
		Gets the final average log-likelihood of the training data.
		@return average log-likelihood
		~#
		method : public : GetLogLikelihood() ~ Float {
			return @log_likelihood;
		}

		#~
		Gets the number of EM iterations actually run.
		@return iterations run
		~#
		method : public : GetIterationsRun() ~ Int {
			return @iterations_run;
		}

		#~
		Whether the mixture has been fitted.
		@return true if fitted
		~#
		method : public : IsFitted() ~ Bool {
			return @is_fitted;
		}

		#~
		Saves the fitted mixture to a file.
		@param filename file to store to
		@return true if successful, false otherwise
		~#
		method : public : Store(filename : String) ~ Bool {
			if(<>@is_fitted) {
				return false;
			};

			serializer := System.IO.Serializer->New();
			serializer->Write(@num_components);

			mean_dims := @means->Size();
			cols := mean_dims[1];
			serializer->Write(cols);

			each(c : @num_components) {
				serializer->Write(@weights[c]);
			};
			each(c : @num_components) {
				each(j : cols) {
					serializer->Write(@means[c,j]);
				};
			};
			each(c : @num_components) {
				each(j : cols) {
					serializer->Write(@variances[c,j]);
				};
			};
			serializer->Write(@log_likelihood);

			return System.IO.Filesystem.FileWriter->WriteFile(filename, serializer->Serialize());
		}

		#~
		Loads a fitted mixture from a file.
		@param filename file to load from
		@return fitted mixture, or Nil on failure
		~#
		function : Load(filename : String) ~ GaussianMixture {
			data := System.IO.Filesystem.FileReader->ReadBinaryFile(filename);
			if(data = Nil) {
				return Nil;
			};

			deserializer := System.IO.Deserializer->New(data);
			num_components := deserializer->ReadInt();
			cols := deserializer->ReadInt();
			if(num_components < 1 | cols < 1) {
				return Nil;
			};

			weights := Float->New[num_components];
			each(c : num_components) {
				weights[c] := deserializer->ReadFloat();
			};

			means := Float->New[num_components, cols];
			each(c : num_components) {
				each(j : cols) {
					means[c,j] := deserializer->ReadFloat();
				};
			};

			variances := Float->New[num_components, cols];
			each(c : num_components) {
				each(j : cols) {
					variances[c,j] := deserializer->ReadFloat();
				};
			};

			log_likelihood := deserializer->ReadFloat();

			return GaussianMixture->New(num_components, weights, means, variances, log_likelihood);
		}
	}

	#~
	K-Means grouping result
	~#
	class KMeansGrouping {
		@groups : Hash<String, KMeansGroup>;
		@group_names : String[];
		@dunn_index : Float;

		@debug : static : Bool;

		New(groups : Hash<String, Vector<FloatArrayRef>>) {
			group_key_values := groups->GetKeyValues()<Pair<String, Vector<FloatArrayRef>>>;
			@groups := Hash->New()<String, KMeansGroup>;
			@group_names := String->New[group_key_values->Size()];			
			@dunn_index := -1.0;
			
			each(i : group_key_values) {
				group_key_value := group_key_values->Get(i);

				group := group_key_value->GetSecond();
				group_name := group_key_value->GetFirst();
				@group_names[i] := group_name->Copy();
				@groups->Insert(group_name, KMeansGroup->New(group_name, group));
			};
		}

		#~
		Get the number of groups
		@return number of groups
		~#
		method : public : Size() ~ Int {
			return @groups->Size();
		}

		#~
		Get a group by index
		@param i index
		@return group
		~#
		method : public : Get(i : Int) ~ KMeansGroup {
			if(i > -1 & i < @group_names->Size()) {
				return @groups->Find(@group_names[i])
			};

			return Nil;
		}

		#~
		Get an array of group names
		@return array of group names
		~#
		method : public : GetGroupNames() ~ String[] {
			return @group_names;
		}

		#~
		Get a group by name
		@param name group name
		@return group
		~#
		method : public : GetGroup(name : String) ~ KMeansGroup {
			return @groups->Find(name);
		}

		#~
		Calculates the Dunn index
		@param groups K-Mean grouping
		@return Dunn index, higher values indicate more distinct clusters
		~#
		method : public : GetDunnIndex() ~ Float {
			if(@dunn_index < 0.0) {
				group_key_values := @groups->GetKeyValues()<Pair<String, KMeansGroup>>;

				max_intra_distance := 0.0;
				each(group_key_value in group_key_values) {
					group := group_key_value->GetSecond()->GetValues();
					group_name := group_key_value->GetFirst();
					
					if(@debug) {
						group_size := group->Size();
						"group: name='{$group_name}', size={$group_size}\n---"->PrintLine();
					};

					each(left_array in group) {			
						each(right_array in group) {
							if(left_array <> right_array) {
								distance := KMeans->Distance(left_array, right_array);
								if(distance > max_intra_distance) {
									max_intra_distance := distance;
								}
							};
						};
					};
				};

				if(@debug) {
					"max_intra_distance={$max_intra_distance}\n---"->PrintLine();
				};

				min_inter_distance := Float->Inf();
				each(left_key_value in group_key_values) {
					left_group := left_key_value->GetSecond()->GetValues();
					left_group_name := left_key_value->GetFirst();

					each(right_key_value in group_key_values) {
						right_group := right_key_value->GetSecond()->GetValues();
						right_group_name := right_key_value->GetFirst();
						if(<>left_group_name->Equals(right_group_name)) {
							each(left_array in left_group) {
								each(right_array in right_group) {
									distance := KMeans->Distance(left_array, right_array);
									if(distance < min_inter_distance) {
										min_inter_distance := distance;
									};
								};
							};
						};
					};
				};

				if(@debug) {
					"min_inter_distance={$min_inter_distance}\n---"->PrintLine();
				};

				@dunn_index := min_inter_distance / max_intra_distance;
			};

			return @dunn_index;
		}
		
		#~
		String representation of the object
		@return groups representation of the object
		~#
		method : public : ToString() ~ String {
			buffer := "";

			buffer->Append('[');
			group_key_values := @groups->GetKeyValues()<Pair<String, KMeansGroup>>;			
			each(i : group_key_values) {
				group_key_value := group_key_values->Get(i);
				group := group_key_value->GetSecond();
				group_name := group_key_value->GetFirst();

				buffer->Append("{\"name\": \"");
				buffer->Append(group_name);
				buffer->Append("\",\"values\":[");
				buffer->Append(group->ToString());
				buffer->Append("]}");

				if(i + 1 < group_key_values->Size()) {
					buffer->Append(',');
				};
			};
			buffer->Append(']');

			return buffer;
		}
	}

	#~
	KMeans group
	~#
	class KMeansGroup {
		@name : String;
		@arrays : Vector<FloatArrayRef>;

		New(name : String, arrays : Vector<FloatArrayRef>) {
			@name := name;
			@arrays := arrays;
		}

		#~
		Get the name of the group
		@return name of the group
		~#
		method : public : GetName() ~ String {
			return @name;
		}

		#~
		Get group values
		@return group values
		~#
		method : public : GetValues() ~ Vector<FloatArrayRef> {
			return @arrays;
		}

		#~
		Get group values as an array
		@param i index
		@return group values as an array
		~#
		method : public : GetArrayValue(i : Int) ~ Float[] {
			if(i > -1 & i < @arrays->Size()) {
				array := @arrays->Get(i)->Get();
				columns := array->Size();

				matrix := Float->New[columns];
				each(j : array) {
					matrix[j] := array[j];
				};

				return matrix;

			};

			return Nil;
		}

		#~
		Get the size of the group
		@return size of the group
		~#
		method : public : Size() ~ Int {
			return @arrays->Size();
		}

		#~
		Get array by index
		@param i index
		@return array
		~#
		method : public : Get(i : Int) ~ FloatArrayRef {
			if(i > -1 & i < @arrays->Size()) {
				return @arrays->Get(i);
			};

			return Nil;
		}

		#~
		Get group as a value matrix
		@return value matrix
		~#
		method : native : public : GetArrayValues() ~ Float[,] {
			matrix : Float[,];

			if(<>@arrays->IsEmpty()) {
				rows := @arrays->Size();
				array := @arrays->Get(0)->Get();
				columns := array->Size();

				matrix := Float->New[rows, columns];
				each(i : @arrays) {
					array := @arrays->Get(i)->Get();
					each(j : array) {
						matrix[i, j] := array[j];
					}
				};
			};

			return matrix;
		}

		#~
		String representation of the object
		@return groups representation of the object
		~#
		method : public : ToString() ~ String {
			buffer := "";

			if(<>@arrays->IsEmpty()) {
				each(i : @arrays) {
					array := @arrays->Get(i)->Get();
					buffer->Append(array->ToString());
					if(i + 1 < @arrays->Size()) {
						buffer->Append(',');
					};
				};
			};

			return buffer;
		}
	}

	#~
	Feature scaling and normalization utilities
	~#
	class FeatureScaler {
		#~
		Standardizes features by removing mean and scaling to unit variance (Z-score normalization)
		@param data input matrix
		@return standardized matrix with mean=0 and std=1
		~#
		function : native : StandardScaler(data : Float[,]) ~ Float[,] {
			dims := data->Size();
			rows := dims[0];
			cols := dims[1];

			result := Float->New[rows, cols];

			# Standardize each column
			each(col : cols) {
				# Calculate mean
				sum := 0.0;
				each(row : rows) {
					sum += data[row, col];
				};
				mean := sum / rows->As(Float);

				# Calculate standard deviation
				sum_sq := 0.0;
				each(row : rows) {
					diff := data[row, col] - mean;
					sum_sq += diff * diff;
				};
				std := Float->Sqrt(sum_sq / rows->As(Float));

				# Standardize
				each(row : rows) {
					if(std > 0.0) {
						result[row, col] := (data[row, col] - mean) / std;
					}
					else {
						result[row, col] := 0.0;
					};
				};
			};

			return result;
		}

		#~
		Scales features to a [0, 1] range (Min-Max normalization)
		@param data input matrix
		@return scaled matrix with values in [0, 1]
		~#
		function : native : MinMaxScaler(data : Float[,]) ~ Float[,] {
			dims := data->Size();
			rows := dims[0];
			cols := dims[1];

			result := Float->New[rows, cols];

			# Scale each column
			each(col : cols) {
				# Find min and max
				min_val := data[0, col];
				max_val := data[0, col];

				each(row : rows) {
					if(data[row, col] < min_val) {
						min_val := data[row, col];
					};
					if(data[row, col] > max_val) {
						max_val := data[row, col];
					};
				};

				# Scale to [0, 1]
				range := max_val - min_val;
				each(row : rows) {
					if(range > 0.0) {
						result[row, col] := (data[row, col] - min_val) / range;
					}
					else {
						result[row, col] := 0.0;
					};
				};
			};

			return result;
		}

		#~
		Normalizes each row to unit norm (L2 normalization)
		@param data input matrix
		@return normalized matrix where each row has L2 norm = 1
		~#
		function : native : Normalize(data : Float[,]) ~ Float[,] {
			dims := data->Size();
			rows := dims[0];
			cols := dims[1];

			result := Float->New[rows, cols];

			# Normalize each row
			each(row : rows) {
				# Calculate L2 norm
				sum_sq := 0.0;
				each(col : cols) {
					sum_sq += data[row, col] * data[row, col];
				};
				norm := Float->Sqrt(sum_sq);

				# Normalize
				each(col : cols) {
					if(norm > 0.0) {
						result[row, col] := data[row, col] / norm;
					}
					else {
						result[row, col] := 0.0;
					};
				};
			};

			return result;
		}
	}

	#~
	Model evaluation metrics for classification tasks
	~#
	class Metrics {
		#~
		Calculates accuracy: (TP + TN) / Total
		@param predictions predicted boolean values
		@param actuals actual boolean values
		@return accuracy score between 0.0 and 1.0
		~#
		function : native : Accuracy(predictions : Bool[], actuals : Bool[]) ~ Float {
			if(predictions->Size() <> actuals->Size() | predictions->Size() = 0) {
				return 0.0;
			};

			correct := 0;
			each(i : predictions) {
				if(predictions[i] = actuals[i]) {
					correct += 1;
				};
			};

			return correct->As(Float) / predictions->Size()->As(Float);
		}

		#~
		Calculates precision: TP / (TP + FP)
		@param predictions predicted boolean values
		@param actuals actual boolean values
		@return precision score between 0.0 and 1.0
		~#
		function : native : Precision(predictions : Bool[], actuals : Bool[]) ~ Float {
			if(predictions->Size() <> actuals->Size() | predictions->Size() = 0) {
				return 0.0;
			};

			tp := 0; # True Positives
			fp := 0; # False Positives

			each(i : predictions) {
				if(predictions[i] & actuals[i]) {
					tp += 1;
				}
				else if(predictions[i] & <>actuals[i]) {
					fp += 1;
				};
			};

			if(tp + fp = 0) {
				return 0.0;
			};

			return tp->As(Float) / (tp + fp)->As(Float);
		}

		#~
		Calculates recall (sensitivity): TP / (TP + FN)
		@param predictions predicted boolean values
		@param actuals actual boolean values
		@return recall score between 0.0 and 1.0
		~#
		function : native : Recall(predictions : Bool[], actuals : Bool[]) ~ Float {
			if(predictions->Size() <> actuals->Size() | predictions->Size() = 0) {
				return 0.0;
			};

			tp := 0; # True Positives
			fn := 0; # False Negatives

			each(i : predictions) {
				if(predictions[i] & actuals[i]) {
					tp += 1;
				}
				else if(<>predictions[i] & actuals[i]) {
					fn += 1;
				};
			};

			if(tp + fn = 0) {
				return 0.0;
			};

			return tp->As(Float) / (tp + fn)->As(Float);
		}

		#~
		Calculates F1 score: 2 * (Precision * Recall) / (Precision + Recall)
		@param predictions predicted boolean values
		@param actuals actual boolean values
		@return F1 score between 0.0 and 1.0
		~#
		function : native : F1Score(predictions : Bool[], actuals : Bool[]) ~ Float {
			precision := Precision(predictions, actuals);
			recall := Recall(predictions, actuals);

			if(precision + recall = 0.0) {
				return 0.0;
			};

			return 2.0 * (precision * recall) / (precision + recall);
		}

		#~
		Creates a confusion matrix
		@param predictions predicted boolean values
		@param actuals actual boolean values
		@return 2x2 confusion matrix [[TN, FP], [FN, TP]]
		~#
		function : native : ConfusionMatrix(predictions : Bool[], actuals : Bool[]) ~ Int[,] {
			matrix := Int->New[2, 2];

			if(predictions->Size() <> actuals->Size() | predictions->Size() = 0) {
				return matrix;
			};

			each(i : predictions) {
				# TN (0,0), FP (0,1), FN (1,0), TP (1,1)
				pred_idx := predictions[i] ? 1 : 0;
				actual_idx := actuals[i] ? 1 : 0;
				matrix[actual_idx, pred_idx] += 1;
			};

			return matrix;
		}

		#~
		Calculates Matthews Correlation Coefficient (MCC)
		@param predictions predicted boolean values
		@param actuals actual boolean values
		@return MCC score between -1.0 and 1.0
		~#
		function : native : MCC(predictions : Bool[], actuals : Bool[]) ~ Float {
			if(predictions->Size() <> actuals->Size() | predictions->Size() = 0) {
				return 0.0;
			};

			tp := 0; tn := 0; fp := 0; fn := 0;

			each(i : predictions) {
				if(predictions[i] & actuals[i]) {
					tp += 1;
				}
				else if(<>predictions[i] & <>actuals[i]) {
					tn += 1;
				}
				else if(predictions[i] & <>actuals[i]) {
					fp += 1;
				}
				else {
					fn += 1;
				};
			};

			numerator := (tp * tn - fp * fn)->As(Float);
			denominator := Float->Sqrt((tp + fp)->As(Float) * (tp + fn)->As(Float) *
			                           (tn + fp)->As(Float) * (tn + fn)->As(Float));

			if(denominator = 0.0) {
				return 0.0;
			};

			return numerator / denominator;
		}

		#~
		Prints a formatted confusion matrix
		@param matrix 2x2 confusion matrix
		~#
		function : native : PrintConfusionMatrix(matrix : Int[,]) ~ Nil {
			tn := matrix[0,0];
			fp := matrix[0,1];
			fn := matrix[1,0];
			tp := matrix[1,1];

			"Confusion Matrix:"->PrintLine();
			"                Predicted"->PrintLine();
			"              Negative  Positive"->PrintLine();
			"Actual Neg  |   {$tn}   |   {$fp}   |"->PrintLine();
			"Actual Pos  |   {$fn}   |   {$tp}   |"->PrintLine();
		}
	}

	#~
	Cross-validation utilities for model evaluation
	~#
	class CrossValidation {
		#~
		Splits data into K folds for cross-validation
		@param data input matrix
		@param k number of folds
		@return array of K fold indices
		~#
		function : native : KFold(data : Float[,], k : Int) ~ Vector[]<IntRef> {
			dims := data->Size();
			rows := dims[0];

			if(k <= 0 | k > rows) {
				return Nil;
			};

			fold_size := rows / k;
			indices := Int->New[rows];
			each(i : rows) {
				indices[i] := i;
			};

			# Shuffle indices
			each(i : rows) {
				j := (rows - 1)->Random();
				temp := indices[i];
				indices[i] := indices[j];
				indices[j] := temp;
			};

			# Create folds
			folds := Vector->New[k]<IntRef>;
			each(fold : k) {
				fold_indices := Vector->New()<IntRef>;
				start := fold * fold_size;
				ending := fold = k - 1 ? rows : (fold + 1) * fold_size;

				for(i := start; i < ending; i += 1;) {
					fold_indices->AddBack(indices[i]);
				};

				folds[fold] := fold_indices;
			};

			return folds;
		}

		#~
		Splits data into training and test sets
		@param data input matrix
		@param test_ratio percentage of data for testing (0.0 to 1.0)
		@return array with [training_data, test_data]
		~#
		function : native : TrainTestSplit(data : Float[,], test_ratio : Float) ~ FloatMatrixRef[] {
			if(test_ratio <= 0.0 | test_ratio >= 1.0) {
				return Nil;
			};

			dims := data->Size();
			rows := dims[0];
			cols := dims[1];

			test_size := (rows->As(Float) * test_ratio)->As(Int);
			train_size := rows - test_size;

			# Shuffle indices
			indices := Int->New[rows];
			each(i : rows) {
				indices[i] := i;
			};

			each(i : rows) {
				j := (rows - 1)->Random();
				temp := indices[i];
				indices[i] := indices[j];
				indices[j] := temp;
			};

			# Split data
			train_data := Float->New[train_size, cols];
			test_data := Float->New[test_size, cols];

			each(i : train_size) {
				idx := indices[i];
				each(j : cols) {
					train_data[i, j] := data[idx, j];
				};
			};

			for(i := train_size; i < rows; i += 1;) {
				idx := indices[i];
				each(j : cols) {
					test_data[i - train_size, j] := data[idx, j];
				};
			};

			result := FloatMatrixRef->New[2];
			result[0] := FloatMatrixRef->New(train_data);
			result[1] := FloatMatrixRef->New(test_data);

			return result;
		}
	}
}
