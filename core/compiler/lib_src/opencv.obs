		#~
		Normalizes the image for neural network preprocessing.
		Converts the image to float, normalizes to [0,1], converts BGR to RGB,
		subtracts the given mean values, and divides by the given std values per channel.
		Returns the result as a flattened CHW tensor (Float[]).
		@param mean_r mean value for the red channel
		@param mean_g mean value for the green channel
		@param mean_b mean value for the blue channel
		@param std_r standard deviation for the red channel
		@param std_g standard deviation for the green channel
		@param std_b standard deviation for the blue channel
		@return flattened CHW Float[] tensor suitable for ONNX inference
		~#
		method : public : Normalize(mean_r : Float, mean_g : Float, mean_b : Float,
				std_r : Float, std_g : Float, std_b : Float) ~ Float[] {
			array_args := Base->New[8];

			array_args[0] := FloatArrayRef->New();
			array_args[1] := @self;
			array_args[2] := FloatRef->New(mean_r);
			array_args[3] := FloatRef->New(mean_g);
			array_args[4] := FloatRef->New(mean_b);
			array_args[5] := FloatRef->New(std_r);
			array_args[6] := FloatRef->New(std_g);
			array_args[7] := FloatRef->New(std_b);

			Proxy->GetDllProxy()->CallFunction("opencv_normalize", array_args);

			holder := array_args[0]->As(FloatArrayRef);
			return holder->Get();
		}
	}

	#~
	OpenCV VideoWriter for writing video files
	~#
	class VideoWriter {
		@writer : Int;

		#~
		Creates a new VideoWriter.
		@param filename output video file path
		@param fourcc 4-character codec code (use FourCC to compute)
		@param fps frames per second
		@param width frame width
		@param height frame height
		~#
		New(filename : String, fourcc : Int, fps : Float, width : Int, height : Int) {
			array_args := Base->New[6];

			array_args[0] := IntRef->New();
			array_args[1] := filename;
			array_args[2] := IntRef->New(fourcc);
			array_args[3] := FloatRef->New(fps);
			array_args[4] := IntRef->New(width);
			array_args[5] := IntRef->New(height);

			Proxy->GetDllProxy()->CallFunction("opencv_new_video_writer", array_args);

			value := array_args[0]->As(IntRef);
			@writer := value->Get();
		}

		#~
		Computes a FourCC code from four characters.
		Example: FourCC('m', 'p', '4', 'v') for MP4V codec.
		@param c1 first character
		@param c2 second character
		@param c3 third character
		@param c4 fourth character
		@return integer FourCC code
		~#
		function : FourCC(c1 : Char, c2 : Char, c3 : Char, c4 : Char) ~ Int {
			array_args := Base->New[5];

			array_args[0] := IntRef->New();
			array_args[1] := IntRef->New(c1->As(Int));
			array_args[2] := IntRef->New(c2->As(Int));
			array_args[3] := IntRef->New(c3->As(Int));
			array_args[4] := IntRef->New(c4->As(Int));

			Proxy->GetDllProxy()->CallFunction("opencv_video_writer_fourcc", array_args);

			value := array_args[0]->As(IntRef);
			return value->Get();
		}

		#~
		Writes a frame to the video file.
		@param image the frame to write
		~#
		method : public : Write(image : Image) ~ Nil {
			array_args := Base->New[2];

			array_args[0] := IntRef->New(@writer);
			array_args[1] := image;

			Proxy->GetDllProxy()->CallFunction("opencv_video_writer_write", array_args);
		}

		#~
		Checks if the VideoWriter has been successfully opened.
		@return true if the writer is open, false otherwise
		~#
		method : public : IsOpen() ~ Bool {
			array_args := Base->New[2];

			array_args[0] := IntRef->New();
			array_args[1] := IntRef->New(@writer);
			Proxy->GetDllProxy()->CallFunction("opencv_video_writer_is_open", array_args);

			value := array_args[0]->As(IntRef);
			return value->Get() = 0 ? false : true;
		}

		#~
		Releases the VideoWriter and closes the file.
		~#
		method : public : Release() ~ Nil {
			array_args := Base->New[1];

			array_args[0] := IntRef->New(@writer);
			Proxy->GetDllProxy()->CallFunction("opencv_video_writer_release", array_args);
		}
	}

	#~
	OpenCV point
	~#
	class Point {
		@x : Int;
		@y : Int;

		#~
		Constructor
		@param x x-position
		@param y y-position
		~#
		New(x : Int, y : Int) {
			@x := x;
			@y := y;
		}

		#~
		Get X position
		@return x-position
		~#
		method : public : GetX() ~ Int {
			return @x;
		}

		#~
		Get Y position
		@return y-position
		~#
		method : public : GetY() ~ Int {
			return @y;
		}
	}

	#~
	OpenCV rectangle
	~#
	class Rect from Point {
		@width : Int;
		@height : Int;

		#~
		Constructor
		@param x x-position
		@param y y-position
		@param width width
		@param height height
		~#
		New(x : Int, y : Int, width : Int, height : Int) {
			Parent(x, y);

			@width := width;
			@height := height;
		}

		#~
		Get width
		@return width
		~#
		method : public : GetWidth() ~ Int {
			return @width;
		}

		#~
		Get height
		@return height
		~#
		method : public : GetHeight() ~ Int {
			return @height;
		}

		#~
		JSON representation 
		@return JSON representation 
		~#
		method : public : ToJson() ~ JsonElement {
			elem_json := JsonElement->New(JsonElement->JsonType->OBJECT);

			elem_json->Insert("width", @width);
			elem_json->Insert("height", @height);

			return elem_json;
		}
	}

	#~
	OpenCV size
	~#
	class Size {
		@width : Int;
		@height : Int;

		#~
		Constructor
		@param width width
		@param height height
		~#
		New(width : Int, height : Int) {
			@width := width;
			@height := height;
		}

		#~
		Get width
		@return width
		~#
		method : public : GetWidth() ~ Int {
			return @width;
		}

		#~
		Get height
		@return height
		~#
		method : public : GetHeight() ~ Int {
			return @height;
		}
	}

	#~
	OpenCV scalar
	~#
	class Scalar {
		@v0 : Float;
		@v1 : Float;
		@v2 : Float;
		@v3 : Float;

		#~
		Constructor
		@param v0 value 0
		@param v1 value 1
		@param v2 value 2
		@param v3 value 3
		~#
		New(v0 : Float, v1 : Float, v2 : Float := 0.0, v3 : Float := 0.0) {
			@v0 := v0;
			@v1 := v1;
			@v2 := v2;
			@v3 := v3;
		}

		#~
		Get value 0
		@return value 0
		~#
		method : public : GetV0() ~ Float {
			return @v0;
		}

		#~
		Get value 1
		@return value 1
		~#
		method : public : GetV1() ~ Float {
			return @v1;
		}

		#~
		Get value 2
		@return value 2
		~#
		method : public : GetV2() ~ Float {
			return @v2;
		}

		#~
		Get value 3
		@return value 3
		~#
		method : public : GetV3() ~ Float {
			return @v3;
		}
	}

	#~
	OpenCV font values
	~#
	consts Font {
		FONT_HERSHEY_SIMPLEX := 0,
		FONT_HERSHEY_PLAIN := 1,
		FONT_HERSHEY_DUPLEX := 2,
		FONT_HERSHEY_COMPLEX := 3,
		FONT_HERSHEY_TRIPLEX := 4,
		FONT_HERSHEY_COMPLEX_SMALL := 5,
		FONT_HERSHEY_SCRIPT_SIMPLEX := 6,
		FONT_HERSHEY_SCRIPT_COMPLEX := 7,
		FONT_ITALIC := 16
	}

	#~
	OpenCV line values
	~#
	consts LineType {
	    FILLED := -1,
	    LINE_4 := 4,
	    LINE_8 := 8,
	    LINE_AA := 16
	}

	#~
	OpenCV interpolation values
	~#
	consts InterpolationFlags {
	    INTER_NEAREST := 0,
	    INTER_LINEAR := 1,
	    INTER_CUBIC := 2,
	    INTER_AREA := 3,
	    INTER_LANCZOS4 := 4,
	    INTER_LINEAR_EXACT := 5,
	    INTER_NEAREST_EXACT := 6,
	    INTER_MAX := 7,
	    WARP_FILL_OUTLIERS := 8,
	    WARP_INVERSE_MAP := 16,
	    WARP_RELATIVE_MAP := 32
	}

	#~
	OpenCV color conversion codes
	~#
	consts ColorConversionCodes {
		BGR2RGB := 4,
		BGR2GRAY := 6,
		RGB2GRAY := 7,
		BGR2HSV := 40,
		BGR2Lab := 44,
		HSV2BGR := 54
	}

	#~
	OpenCV threshold types
	~#
	consts ThresholdTypes {
		BINARY := 0,
		BINARY_INV := 1,
		TRUNC := 2,
		TOZERO := 3,
		TOZERO_INV := 4,
		OTSU := 8
	}

	#~
	OpenCV morphological shape constants for structuring elements
	~#
	consts MorphShapes {
		MORPH_RECT := 0,
		MORPH_CROSS := 1,
		MORPH_ELLIPSE := 2
	}

	#~
	OpenCV morphological operation types
	~#
	consts MorphTypes {
		MORPH_ERODE := 0,
		MORPH_DILATE := 1,
		MORPH_OPEN := 2,
		MORPH_CLOSE := 3,
		MORPH_GRADIENT := 4
	}

	#~
	OpenCV contour retrieval modes for FindContours
	~#
	consts RetrievalModes {
		RETR_EXTERNAL := 0,
		RETR_LIST := 1,
		RETR_CCOMP := 2,
		RETR_TREE := 3
	}

	#~
	OpenCV contour approximation methods for FindContours
	~#
	consts ContourApproximationModes {
		CHAIN_APPROX_NONE := 1,
		CHAIN_APPROX_SIMPLE := 2
	}
}
